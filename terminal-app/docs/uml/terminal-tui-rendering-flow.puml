@startuml Terminal UI - Rendering Flow Architecture

title Terminal UI - Rendering Flow and Lifecycle

package "TerminalUI Lifecycle" {
    class TerminalUI {
        - terminal: Terminal<CrosstermBackend>
        - event_polling_paused: Arc<AtomicBool>
        ---
        + new() -> Result<Self>
        + render(state: &TerminalState) -> Result<()>
        + clear() -> Result<()>
        + cleanup() -> Result<()>
        + suspend() -> Result<()>
        + resume() -> Result<()>
        + event_polling_pause_flag() -> Arc<AtomicBool>
    }

    note right of TerminalUI
        Constructor (new):
        - enable_raw_mode()
        - create CrosstermBackend
        - enter alternate screen
        - enable mouse capture
        - init Terminal

        Destructor (Drop):
        - calls cleanup()

        Render path:
        - terminal.draw(|frame| { render_frame() })
        - handles all drawing

        Suspend path:
        - pause event polling (atomic flag)
        - flush output
        - leave alternate screen
        - disable raw mode

        Resume path:
        - enable raw mode
        - enter alternate screen
        - clear screen
        - resume event polling
    end note
}

package "Rendering Logic" {
    note as RenderNote
        Main entry point: TerminalUI::render()
        Called once per event loop iteration

        Flow:
        1. terminal.draw(|frame| render_frame())
        2. render_frame() builds unified content
        3. All content (output + prompt) in single area
        4. Scrollbar rendered if needed
        5. Cursor positioned on prompt line
    end note

    class render_frame {
        {method} frame: &mut Frame
        {method} state: &mut TerminalState
        ---
        1. Get frame area size
        2. Call render_unified_content()
    }

    class render_unified_content {
        {method} frame: &mut Frame
        {method} area: Rect
        {method} state: &mut TerminalState
        ---
        Phase 1: Build Content Lines
        - Get parsed_lines from OutputBuffer
        - Add pending_interaction if any
        - Build prompt line with colors
        - Append prompt to all_lines

        Phase 2: Calculate Scroll
        - Count total_lines
        - Calculate max_scroll
        - Sync scroll position to state

        Phase 3: Render Content
        - Create Paragraph with all_lines
        - Apply scroll offset
        - Render widget to frame

        Phase 4: Render Scrollbar (if needed)
        - Calculate scrollbar position
        - Create ScrollbarState
        - Render scrollbar widget

        Phase 5: Position Cursor
        - Calculate prompt_line_index
        - Determine cursor_position based on input
        - Call frame.set_cursor_position()
    }

    render_frame --> render_unified_content : calls >
}

package "Content Assembly (render_unified_content)" {
    class "Phase 1: Content Lines" as P1 {
        output_lines = state.output.parsed_lines()
        ---
        if pending_interaction:
            add CommandApproval lines
            add Question lines

        if mode == AwaitingInput:
            prompt = "Answer: "
        else if mode == AwaitingApproval:
            prompt = "Do you want to execute..."
        else if mode == AwaitingMoreInput:
            prompt = "> "
        else:
            prompt = state.get_prompt()

        prompt_line = [prompt_span + input_text_span]
        all_lines.push(prompt_line)
    }
    note right of P1
        Creates final content vector
        with styled prompt and input.

        Colors set by get_prompt_color():
        - Normal: Green
        - ExecutingCommand: Yellow
        - WaitingLLM: Blue
        - PromptingInstall: Magenta
        - AwaitingCommandApproval: Cyan
        - AwaitingAnswer: Cyan
        - AwaitingMoreInput: Magenta

        Password mode: replaces input
        with "*" for display
    end note

    class "Phase 2: Scroll Calculations" as P2 {
        total_lines = all_lines.len()
        visible_height = area.height
        extra_lines = total_lines - output_line_count
        ---
        output.set_extra_lines(extra_lines)
        output.set_visible_lines(visible_height)
        ---
        scroll_position = output.scroll_position()
        max_scroll = total_lines - visible_height
        effective_scroll = min(scroll_position, max_scroll)
        ---
        needs_scrollbar = total_lines > visible_height
    }
    note right of P2
        Coordinates scroll calculations:
        - Updates OutputBuffer state
        - Clamps scroll to valid range
        - Determines scrollbar visibility
    end note

    class "Phase 3: Render Content" as P3 {
        paragraph = Paragraph::new(all_lines)
        .scroll((effective_scroll, 0))
        ---
        frame.render_widget(paragraph, area)
    }
    note right of P3
        Renders scrollable paragraph widget:
        - Uses effective_scroll for view window
        - Ratatui handles line wrapping
        - Applies text styles/colors
    end note

    class "Phase 4: Render Scrollbar" as P4 {
        if needs_scrollbar:
            state.scrollbar_info =
              ScrollbarInfo {
                column,
                height,
                total_lines,
                visible_lines
              }

            scrollbar_state =
              ScrollbarState::default()
              .content_length(max_scroll)
              .position(effective_scroll)

            scrollbar = Scrollbar::new(
              ScrollbarOrientation::VerticalRight
            )

            frame.render_stateful_widget(
              scrollbar, area, &mut scrollbar_state
            )
    }
    note right of P4
        Renders scrollbar on right edge
        when content exceeds viewport.

        ScrollbarState configuration:
        - content_length = max_scroll + 1
        - position = effective_scroll
        - Properly positions thumb at bottom
        - Updates ScrollbarInfo for mouse
    end note

    class "Phase 5: Cursor Position" as P5 {
        prompt_line_index = total_lines - 1
        prompt_screen_row = prompt_line_index - effective_scroll
        ---
        if prompt_screen_row < visible_height:
            char_idx = input.cursor_position()
            if is_password_mode:
                input_width = char_idx
            else:
                input_width = char_display_width
            ---
            total_width = prompt_width + input_width
            cursor_x = area.x + total_width
            cursor_y = area.y + prompt_screen_row
            ---
            frame.set_cursor_position((x, y))
    }
    note right of P5
        Positions cursor on prompt line.

        Only shows cursor if prompt is
        visible in current viewport.

        Uses unicode_width for accurate
        display width calculation.

        Password mode shows cursor based
        on character count, not width.
    end note

    P1 --> P2 : content ready
    P2 --> P3 : scroll calculated
    P3 --> P4 : content rendered
    P4 --> P5 : area available
}

package "State Sources" {
    class TerminalState #f9f9f9 {
        - output: OutputBuffer
        - input: InputBuffer
        - mode: TerminalMode
        - pending_interaction: Option<PendingInteraction>
    }

    class OutputBuffer #f9f9f9 {
        + parsed_lines() -> &[Line]
        + scroll_position() -> usize
    }

    class InputBuffer #f9f9f9 {
        + text() -> &str
        + cursor_position() -> usize
    }

    TerminalState --> OutputBuffer
    TerminalState --> InputBuffer
}

package "Color and Style Helpers" {
    function "get_prompt_color(mode)" {
        Match TerminalMode:
        - Normal -> Color::Green
        - ExecutingCommand -> Color::Yellow
        - WaitingLLM -> Color::Blue
        - PromptingInstall -> Color::Magenta
        - AwaitingCommandApproval -> Color::Cyan
        - AwaitingAnswer -> Color::Cyan
        - AwaitingMoreInput -> Color::Magenta
    }
}

note bottom
    ARCHITECTURE HIGHLIGHTS:

    1. UNIFIED CONTENT: Output and prompt
       in same scrollable paragraph

    2. SMART SCROLL: Content starts at top,
       grows downward (Linux shell behavior)

    3. AUTO-SCROLL: Only when user was
       already at bottom (no jarring jumps)

    4. CURSOR POSITIONING: Calculated
       relative to visible viewport

    5. SCROLLBAR: Only rendered when
       content exceeds viewport

    6. ANSI PARSING: Done once in
       OutputBuffer, cached for speed

    7. TYPED WIDGETS: Uses ratatui
       Paragraph and Scrollbar
end note

@enduml
