@startuml Input Classification - Chain of Responsibility

' ==============================================================================
' Input Module
' Shows Chain of Responsibility Pattern for input classification
' ==============================================================================

!define CHAIN_COLOR #87CEEB

skinparam class {
    BackgroundColor White
    BorderColor Black
}

' ==============================================================================
' Main Classifier
' ==============================================================================

class InputClassifier {
    - chain: ClassifierChain
    __
    <b>Construction</b>
    + new(): Self
    + with_chain(chain: ClassifierChain): Self
    __
    <b>Classification</b>
    + classify(&self, input: &str): Result<InputType>
    __
    <b>Deprecated</b>
    + {deprecated} add_known_command(&mut self, command: String)
}

enum InputType {
    <b>Command(String, Vec<String>)</b>
    <b>NaturalLanguage(String)</b>
    <b>Empty</b>
}

InputClassifier ..> InputType : <<creates>>
InputClassifier *-- ClassifierChain

' ==============================================================================
' Chain of Responsibility
' ==============================================================================

class ClassifierChain <<Chain>> CHAIN_COLOR {
    - handlers: Vec<Box<dyn InputHandler>>
    __
    <b>Construction</b>
    + new(): Self
    + add_handler(handler: Box<dyn InputHandler>): Self
    __
    <b>Processing</b>
    + process(&self, input: &str): Option<InputType>
    __
    <b>Utilities</b>
    + len(): usize
    + is_empty(): bool
}

interface InputHandler <<Chain>> CHAIN_COLOR {
    + handle(&self, input: &str): Option<InputType>
    + name(): &str
}

ClassifierChain o-- InputHandler : chain
ClassifierChain ..> InputType : <<creates>>

' ==============================================================================
' Concrete Handlers (Order matters!)
' ==============================================================================

class EmptyInputHandler <<Handler 1>> CHAIN_COLOR {
    __
    + new(): Self
}

class KnownCommandHandler <<Handler 2>> CHAIN_COLOR {
    - known_commands: Vec<String>
    __
    <b>Construction</b>
    + new(known_commands: Vec<String>): Self
    + with_defaults(): Self
    __
    <b>Defaults</b>
    - default_known_commands(): Vec<String>
    __
    <b>Logic</b>
    - is_known_command(&self, input: &str): bool
    - parse_as_command(&self, input: &str): Result<InputType>
    + add_command(&mut self, command: String)
}

class CommandSyntaxHandler <<Handler 3>> CHAIN_COLOR {
    __
    <b>Construction</b>
    + new(): Self
    __
    <b>Heuristics</b>
    - looks_like_command(&self, input: &str): bool
    - parse_as_command(&self, input: &str): Result<InputType>
}

class NaturalLanguageHandler <<Handler 4>> CHAIN_COLOR {
    __
    <b>Construction</b>
    + new(): Self
    __
    <b>Multilingual Detection</b>
    - is_likely_natural_language(&self, input: &str): bool
    - has_command_syntax(&self, input: &str): bool
}

class DefaultHandler <<Handler 5>> CHAIN_COLOR {
    __
    + new(): Self
}

InputHandler <|.. EmptyInputHandler : implements
InputHandler <|.. KnownCommandHandler : implements
InputHandler <|.. CommandSyntaxHandler : implements
InputHandler <|.. NaturalLanguageHandler : implements
InputHandler <|.. DefaultHandler : implements

' ==============================================================================
' Parser Utility
' ==============================================================================

class CommandParser {
    __
    <b>Parsing</b>
    + {static} parse(input: &str): Result<(String, Vec<String>)>
    __
    <b>Formatting</b>
    + {static} quote_if_needed(arg: &str): String
    + {static} join(command: &str, args: &[String]): String
}

KnownCommandHandler ..> CommandParser : <<uses>>
CommandSyntaxHandler ..> CommandParser : <<uses>>

' ==============================================================================
' Flow Diagram
' ==============================================================================

note bottom of ClassifierChain
  <b>Processing Flow</b>

  input → EmptyInputHandler
     ↓ (pass)
  KnownCommandHandler (whitelist check)
     ↓ (pass)
  CommandSyntaxHandler (syntax heuristics)
     ↓ (pass)
  NaturalLanguageHandler (NL patterns)
     ↓ (pass)
  DefaultHandler (fallback → NaturalLanguage)

  Primo handler che ritorna Some(InputType) vince
end note

note right of EmptyInputHandler
  <b>Handler 1: EmptyInputHandler</b>

  Gestisce input vuoto o solo whitespace

  Return: InputType::Empty
end note

note right of KnownCommandHandler
  <b>Handler 2: KnownCommandHandler</b>

  Whitelist di comandi conosciuti:
  - Shell: ls, cd, pwd, cat, grep, find, etc.
  - DevOps: kubectl, docker, aws, terraform, etc.
  - Git: git, gh
  - Package managers: apt, yum, brew, etc.

  Fast path: match esatto su comando noto

  Return: InputType::Command(cmd, args)
end note

note right of CommandSyntaxHandler
  <b>Handler 3: CommandSyntaxHandler</b>

  Euristica sintattica:
  - Inizia con ./ o /
  - Contiene flags (-x, --flag)
  - Contiene pipe (|)
  - Contiene redirect (>, <, >>)
  - Contiene path assoluti

  Return: InputType::Command(cmd, args)
end note

note right of NaturalLanguageHandler
  <b>Handler 4: NaturalLanguageHandler</b>

  Pattern multilingua (EN, IT, ES, FR, DE):

  <b>Indicatori NL:</b>
  - Question words: how, what, why, when, where
  - Italian: come, cosa, perché, quando, dove
  - Spanish: cómo, qué, por qué, cuándo, dónde
  - French: comment, quoi, pourquoi, quand, où
  - German: wie, was, warum, wann, wo

  <b>Polite forms:</b>
  - please, per favore, por favor, s'il vous plaît

  Return: InputType::NaturalLanguage(query)
  se nessuna sintassi comando rilevata
end note

note right of DefaultHandler
  <b>Handler 5: DefaultHandler</b>

  Fallback finale:
  Se nessun altro handler gestisce l'input,
  lo tratta come Natural Language.

  Return: InputType::NaturalLanguage(input)

  Design decision: ambiguous → NL
end note

@enduml
