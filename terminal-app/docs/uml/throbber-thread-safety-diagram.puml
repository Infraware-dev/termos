@startuml ThrobberAnimator Thread Safety Model
!theme plain
title "ThrobberAnimator - Thread Safety & Synchronization"

package "Main Thread" {
    participant "Event Handler" as main_handler
    participant "State" as main_state
}

package "Animation Thread" {
    participant "Animator Loop" as anim_thread
}

== Initialization ==
main_handler -> main_state: start_throbber()
main_state -> anim_thread: spawn()
note right of main_state
  Clones Arc<AtomicUsize> (index)
  Clones Arc<AtomicBool> (active)
  Both shared between threads
  Zero-copy, lock-free sharing
end note

== Running State ==
loop Every 100ms (animation thread)
  anim_thread -> anim_thread: if active.load(Relaxed) { index.fetch_add(1, Relaxed) }
  note right of anim_thread
    Uses Relaxed ordering for hot path
    No synchronization cost
    Just increments atomic counter
  end note
end

loop Every 100ms (main thread - render)
  main_handler -> main_state: symbol() → index.load(Relaxed) % len
  note right of main_state
    Reads current index with Relaxed ordering
    Calculates which symbol to show
    No blocking, no locks
  end note
  main_handler -> main_handler: render_prompt(symbol)
end

== Stopping ==
main_handler -> main_state: stop_throbber()
main_state -> anim_thread: active.store(false, SeqCst)
note right of main_state
  Uses SeqCst ordering for stop operation
  Ensures animation thread sees the change
  (not on hot path, so safe to use stronger ordering)
end note

anim_thread -> anim_thread: Notice active=false, exit loop
note right of anim_thread
  Checks active.load(Relaxed)
  Sees false, exits
  Thread terminates gracefully
end note

main_state -> anim_thread: join()
note right of main_state
  Waits for animation thread to finish
  Called in Drop impl for cleanup
end note

== Error Handling ==
note over main_state, anim_thread
  Lock-Free Design Benefits:
  ✓ No deadlocks possible
  ✓ No lock poisoning
  ✓ Minimal contention
  ✓ High-performance on concurrent access

  Atomic Operations:
  - SeqCst for start/stop (correctness)
  - Relaxed for index increment (performance)
  - Balances safety with speed
end note

package "Memory Ordering" {
    class MemoryOrdering {
        Relaxed: No synchronization
        Acquire: Acquire semantics (load)
        Release: Release semantics (store)
        AcqRel: Both acquire & release
        SeqCst: Strongest, sequential consistency
    }
}

note right of MemoryOrdering
  start()/stop() use SeqCst for safety
  index updates use Relaxed (hot path)

  Why Relaxed for index?
  - Symbol display doesn't require ordering
  - No shared data modified
  - Only counter increments (monotonic)
  - Fastest path for 10 FPS render loop
end note

@enduml
