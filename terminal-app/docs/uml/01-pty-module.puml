@startuml "PTY Module - Class Diagram"

!theme plain
skinparam backgroundColor #ffffff
skinparam defaultFontName monospace
skinparam defaultFontSize 10
skinparam classBorderColor #333333
skinparam classBackgroundColor #fffacd
skinparam arrowColor #333333

title "PTY Module - Class Diagram"

package "pty::manager" {
    class PtyManager {
        - session: PtySession
        - current_size: PtySize
        - shell: String
        --
        + new() -> Result<Self>
        + with_size(size: PtySize) -> Result<Self>
        + shell() -> &str
        + size() -> PtySize
        + take_reader() -> Result<PtyReader>
        + take_writer() -> Result<Arc<PtyWriter>>
        + resize(rows: u16, cols: u16) -> Result<()>
        + is_running() -> bool
        + kill() -> Result<()>
        + send_sigint() -> Result<()>
        - detect_shell() -> Result<String>
    }

    note right of PtyManager
        High-level PTY management API
        Spawns persistent shell (zsh/bash/sh)
        Detects available shell at runtime
        Manages reader/writer lifecycle
        Provides signal handling (SIGINT, SIGWINCH)
    end note
}

package "pty::session" {
    class PtySessionConfig {
        + command: String
        + args: Vec<String>
        + working_dir: Option<PathBuf>
        + env: HashMap<String, String>
        + size: PtySize
        --
        + new(command) -> Self
        + args<I, S>(args: I) -> Self
        + working_dir(path) -> Self
        + env(key, value) -> Self
        + size(rows, cols) -> Self
    }

    class PtySession {
        - master: Arc<Mutex<MasterPty>>
        - child: Arc<Mutex<Child>>
        - reader: Option<PtyReader>
        - writer: Option<PtyWriter>
        --
        + new(pair: PtyPair, child: Child) -> Self
        + reader() -> Result<PtyReader>
        + writer() -> Result<PtyWriter>
        + resize(rows: u16, cols: u16) -> Result<()>
        + is_running() -> bool
        + wait() -> Result<ExitStatus>
        + try_wait() -> Result<Option<ExitStatus>>
        + kill() -> Result<()>
        + pid() -> Option<u32>
        + send_sigint() -> Result<()>
        - resize_sync(rows, cols) -> Result<()>
    }

    note bottom of PtySession
        Represents a single PTY session
        Owns master side of PTY pair
        Owns child process handle
        Enables signal delivery via /proc/<pid>/stat
        Takes ownership of reader/writer (one-time call)
    end note
}

package "pty::io" {
    class PtyReader {
        - receiver: Receiver<Vec<u8>>
        - stop_flag: Arc<AtomicBool>
        --
        + new(reader: Box<Read>) -> Self
        + read_available() -> Result<Vec<u8>>
        + read_with_timeout(timeout) -> Result<Vec<u8>>
        + read() -> Result<Vec<u8>>
        + is_alive() -> bool
    }

    class PtyWriter {
        - inner: Arc<Mutex<Box<Write>>>
        --
        + new(writer: Box<Write>) -> Self
        + write(data: &[u8]) -> Result<usize>
        + write_sync(data: &[u8]) -> Result<usize>
        + write_str(s: &str) -> Result<usize>
        + send_byte(byte: u8) -> Result<()>
        + send_interrupt() -> Result<()>
        + send_eof() -> Result<()>
        + send_suspend() -> Result<()>
    }

    note right of PtyReader
        Async reader with dedicated thread
        Spawns background reader thread
        Communicates via tokio channel
        Non-blocking availability check
        Can timeout or block indefinitely
    end note

    note right of PtyWriter
        Async/sync dual-mode writer
        Wraps std::io::Write trait object
        Locked with std::sync::Mutex (not tokio)
        Supports text and raw byte writes
        Provides control character helpers
    end note
}

package "pty::traits" {
    interface PtyWrite {
        + write_bytes(data: &[u8]) -> Result<usize>
    }

    interface PtyControl {
        + resize(rows: u16, cols: u16) -> Result<()>
        + send_sigint() -> Result<()>
    }

    note right of PtyWrite
        Abstraction for writing to PTY
        Enables DI and testing with mocks
        Implemented by PtyWriter
        Thread-safe: Send + Sync
    end note

    note right of PtyControl
        Abstraction for PTY management
        Enables DI and testing with mocks
        Implemented by PtySession
        Signal delivery: SIGINT, SIGWINCH
    end note
}

package "pty::mod" {
    class Pty {
        - system: Box<PtySystem>
        --
        + new() -> Self
        + spawn(cmd, args, size) -> Result<PtySession>
    }

    class "portable_pty" <<third-party>> {
        PtySystem (trait)
        MasterPty (trait)
        Child (trait)
        PtyPair
        PtySize
        CommandBuilder
    }

    note bottom of Pty
        Wrapper around portable_pty
        Abstracts platform-specific PTY
        Configures shell environment
        Sets TERM=xterm-256color
        Sets custom prompt
    end note
}

' Relationships - Composition
PtyManager --> PtySession : owns
PtySession --> PtyReader : provides reader
PtySession --> PtyWriter : provides writer

PtySession --> "portable_pty" : uses for master/child

' Relationships - Implementation
PtyWriter ..|> PtyWrite : implements

PtySession ..|> PtyControl : implements

' Relationships - Usage
Pty --> PtySession : creates via spawn
Pty --> "portable_pty" : uses

' Relationships - Configuration
PtySessionConfig -.-> PtySession : builder pattern

' Thread and Async Model
note right of PtyReader
    **Thread Model:**
    - Spawns dedicated std::thread
    - Background thread: read() blocking call
    - Main thread: async recv() on channel
    - Drop stops thread via atomic flag

    **Memory:** 4KB buffer per read
end note

note right of PtyWriter
    **Concurrency Model:**
    - std::sync::Mutex (not tokio::Mutex)
    - Can be called from async or sync context
    - Panics on lock poisoning (fail-fast)
    - Single Arc clone for multi-owner
end note

' Signal Delivery
note bottom of PtySession
    **SIGINT Delivery (Unix):**
    1. Read /proc/<pid>/stat for tpgid
    2. Send SIGINT to foreground pgid
    3. Fallback: send to shell's pgid

    **SIGWINCH (Resize):**
    - Automatic on resize() call
    - Portable_pty handles syscall
end note

@enduml
