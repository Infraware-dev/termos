@startuml "Render Pipeline - Activity Diagram"

!theme plain
skinparam backgroundColor #ffffff
skinparam defaultFontName monospace
skinparam defaultFontSize 10
skinparam activityBackgroundColor #f0f0ff
skinparam activityBorderColor #333333
skinparam arrowColor #333333

title "egui Rendering Pipeline - Single-Pass Architecture"

start

: **eframe::App::update(ctx, frame)**
: Called at ~60 FPS (or less if idle);

partition "Startup & State" {
    : Apply theme (once);
    : Check window focus;
    : Update cursor blink (530ms interval);
}

partition "Input & PTY Processing" {
    : Poll keyboard input;
    : Process egui events;
    : Poll PTY output (limited);
    : Feed bytes to VTE parser;
    note on the right
        Rate limited by MAX_BYTES_PER_FRAME
        May process 0-4096 bytes per frame
        Auto-scroll to bottom on new output
    end note
}

partition "egui Layout Phase" {
    : Create CentralPanel;
    : Calculate available space;
    : Compute terminal size (cols, rows);
    : Round to char dimensions;
    note on the right
        cols = (width / CHAR_WIDTH).max(20)
        rows = (height / CHAR_HEIGHT).max(5)
        Minimum 20x5 for usability
    end note
}

partition "PTY Resize (if needed)" {
    if (Size changed?) then (yes)
        : Debounce (50ms);
        : Resize terminal handler;
        : Spawn async PTY resize;
        : Update column X coords cache;
        note on the right
            Pre-calculates X positions
            Avoids per-cell multiplication
        end note
    else (no)
        : Skip resize;
    endif
}

partition "Terminal Rendering - Single Pass" {
    : Get grid reference;
    : Get visible_rows;
    : Get cursor position;
    : Get scroll offset;

    : **For each visible row:**
    partition "Per-Row Rendering" {
        : Clear buffers (reuse allocations);
        note on the right
            Buffers:
            - bg_rects
            - text_runs
            - decorations
        end note

        : **Iterate cells once** [single pass];
        partition "Cell Iteration" {
            : For col_idx, cell in row.iter()

            : **Background Batching:**
            : Calculate bg color;
            if (Same as previous?) then (yes)
                : Extend current batch;
            else (no)
                : Flush previous batch to bg_rects;
                : Start new batch;
            endif

            : **Text Batching:**
            : Calculate fg color (handle reverse, dim);
            : Handle space vs. printable;
            if (Space or hidden?) then (yes)
                : Flush text run;
            else (printable)
                if (Same color as previous?) then (yes)
                    : Append char to run;
                else (no)
                    : Flush previous run to text_runs;
                    : Start new run;
                endif
            endif

            : **Decoration Collection:**
            : If underline or strikethrough;
            : Add to decorations (not batched);
        }

        : Flush remaining background batch;
        : Flush remaining text run;
    }

    : **Render Phase - Z-Order:**
    partition "Z-Order Draw" {
        : render_backgrounds(painter, bg_rects);
        note on the right
            Uses Painter::rect_filled()
            One rect per batch
        end note

        : render_text_runs(painter, text_runs);
        note on the right
            Uses Painter::text()
            One text call per batch
            Pre-calculated X coords
        end note

        : render_decorations(painter, decorations);
        note on the right
            Uses Painter::line()
            One line per decoration
        end note
    }
}

partition "Cursor Rendering" {
    if (Cursor visible AND
        at bottom AND
        shell init done AND
        focused?) then (yes)
        : render_cursor(painter, x, y, ...);
        note on the right
            Block cursor or hollow (if unfocused)
            Only at "live" view (scroll_offset=0)
            Blinks at 530ms interval
        end note
    else (no)
        : Skip cursor (scrolled or hidden);
    endif
}

partition "Scrollbar Rendering" {
    if (max_scroll > 0?) then (yes)
        : render_scrollbar(painter, rect, ...);
        note on the right
            Thumb position: (scroll_offset / max_scroll) * height
            Shows scroll position visually
            Enables mouse drag scrolling
        end note
    else (no)
        : No scrollback - skip;
    endif
}

partition "Mouse Input Handling" {
    : Check mouse wheel delta;
    if (Wheel moved?) then (yes)
        : Calculate line delta;
        if (Positive?) then (up)
            : grid.scroll_view_up(lines);
        else (negative - down)
            : grid.scroll_view_down(lines);
        endif
    else (no)
        : No scroll;
    endif
}

partition "Reactive Repaint Scheduling" {
    if (Window focused?) then (yes)
        : Check for user input;
        : Check if cursor needs blink;
        if (PTY data OR user input OR
            blink time?) then (yes)
            : ctx.request_repaint();
            note on the right
                Immediate repaint
                Next vblank
            end note
        else (idle - no changes)
            : Calculate time to next blink;
            : ctx.request_repaint_after(duration);
            note on the right
                Schedule repaint only when needed
                Reduces CPU from ~50% to <5%
            end note
        endif
    else (unfocused)
        : ctx.request_repaint_after(LOW_FPS);
        note on the right
            2 Hz in background
            ~500ms between frames
        end note
    endif
}

stop

note bottom
    **Single-Pass Rendering Optimization:**

    Traditional 3-pass approach:
    ```
    For each cell:
        Render background
    For each cell:
        Render text
    For each cell:
        Render decorations
    ```

    Single-pass approach (current):
    ```
    For each cell (once):
        Collect background/text/decoration
    Render backgrounds (batched)
    Render text (batched)
    Render decorations (collected)
    ```

    **Benefits:**
    - 1 iteration instead of 3
    - Batching reduces draw calls
    - CPU cache efficiency
    - Better for large grids (e.g. 100 rows)

    **Batching Strategy:**
    - Group adjacent cells with same color
    - Backgrounds: rect_filled(x, width, height, color)
    - Text: text(x, y, string, color) - multiple chars
    - Decorations: line() - rare, not batched

    **Performance Characteristics:**
    - Worst case: every cell different color → O(cols) draw calls
    - Best case: solid color → 1 draw call
    - Typical: ~10-20 batches per row

    **Font Caching:**
    - FontId pre-allocated at startup
    - Reused per frame (avoids allocation)
    - Monospace assumption for metrics

    **Column X Coordinate Caching:**
    - Pre-calculated: column_x_coords vec
    - Avoids per-cell float multiplication
    - Rebuilt on window resize

end note

@enduml
