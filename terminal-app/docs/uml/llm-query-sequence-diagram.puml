@startuml LLM Query Flow with Throbber Animation
!theme plain
title "Natural Language Query Execution with Throbber Animation"

actor User
participant "main.rs" as main
participant "TerminalUI" as ui
participant "TerminalState" as state
participant "NaturalLanguageOrchestrator" as orchestrator
participant "LLMClient" as llm_client
participant "ThrobberAnimator" as throbber

== Initialization ==
main -> state: new()
state -> throbber: new() [not started]
note right of state
  TerminalState contains a
  non-running ThrobberAnimator
end note

== Query Start ==
User -> main: Enter natural language query
main -> state: mode = WaitingLLM
main -> state: start_throbber()
state -> throbber: start()
note right of throbber
  Spawns animation thread
  at 100ms interval
  (~10 FPS)
end note

== Render Loop with Animation ==
main -> orchestrator: handle_query(query, state, ui, cancel_token)
orchestrator -> ui: render(state)
note right of ui
  Calls render with WaitingLLM mode
  state.get_prompt_prefix() checks:
  - Is mode WaitingLLM? YES
  - Is throbber running? YES
  - Return "|<symbol>|"

  Animation visible in prompt!
end note

== Parallel Execution ==
par LLM Query Execution
  orchestrator -> llm_client: query_cancellable(query, cancel_token)
  note right of llm_client
    Long-running async future
    - Connects to backend
    - Streams response
    - May take seconds
  end note
else Render Loop (tokio::select!)
  loop every 100ms
    orchestrator -> ui: render(state)
    note right of ui
      Prompt updates:
      |⠋| $ → |⠙| $ → |⠹| $ → |⠸| $
      Animation progresses
    end note
  end
  note right of orchestrator
    tokio::select! polls:
    1. LLM future (prioritized)
    2. Cancellation token
    3. 100ms sleep (render trigger)
  end note
else Throbber Animation Thread
  loop every 100ms
    throbber -> throbber: index += 1
    note right of throbber
      Atomic increment:
      index.fetch_add(1, Relaxed)
      (lock-free synchronization)
    end note
  end
end

== Query Completion ==
llm_client --> orchestrator: LLMQueryResult
orchestrator -> state: stop_throbber()
state -> throbber: stop()
note right of throbber
  Sets active flag to false
  Animation thread exits within ~100ms
end note

orchestrator -> orchestrator: handle_query_result(result, state)
alt Result Type
  case Complete Response
    orchestrator -> state: add_output_lines(formatted)
    orchestrator -> state: mode = Normal
  case CommandApproval
    orchestrator -> state: mode = AwaitingCommandApproval
    orchestrator -> state: pending_interaction = Some(...)
  case Question
    orchestrator -> state: mode = AwaitingAnswer
    orchestrator -> state: pending_interaction = Some(...)
end

== Final Render ==
orchestrator -> ui: render(state)
note right of ui
  Final render shows:
  - Throbber stopped
  - Prompt back to "|~|"
  - Response/approval/question displayed
end note

orchestrator --> orchestrator: return Ok(())

main -> ui: render(state)
main -> main: handle_event() again

note over User, throbber
  Timeline:
  - 0ms: User enters query, throbber starts
  - 0-100ms: First render shows animation
  - 100ms: Throbber increments, re-render shows next symbol
  - ...continues every 100ms...
  - 500-2000ms: LLM response arrives
  - Throbber stops, final render

  User sees continuous smooth animation
  while waiting for LLM response
end note

@enduml
