@startuml "Terminal Module - Class Diagram"

!theme plain
skinparam backgroundColor #ffffff
skinparam defaultFontName monospace
skinparam defaultFontSize 10
skinparam classBorderColor #333333
skinparam classBackgroundColor #e0ffe0
skinparam arrowColor #333333

title "Terminal Module - Class Diagram"

package "terminal::handler" {
    class TerminalHandler {
        - grid: TerminalGrid
        - window_title: String
        --
        + new(rows: u16, cols: u16) -> Self
        + grid() -> &TerminalGrid
        + grid_mut() -> &mut TerminalGrid
        + window_title() -> &str
        + resize(rows: u16, cols: u16)
        - process_sgr(params: &[&[u16]])
    }

    interface "vte::Perform" <<external>> {
        + execute(byte: u8)
        + print(ch: char)
        + csi_dispatch(...)
        + osc_dispatch(...)
        + hook(...)
        + put(...)
        + unhook()
    }

    TerminalHandler ..|> "vte::Perform" : implements

    note right of TerminalHandler
        VTE terminal emulator
        Implements vte::Perform trait
        Processes ANSI escape sequences
        Maintains terminal grid state
        Handles SGR (colors, attributes)
        Updates window title via OSC
    end note
}

package "terminal::grid" {
    class TerminalGrid {
        - cells: Vec<Vec<Cell>>
        - scrollback: Vec<Vec<Cell>>
        - scroll_offset: usize
        - cursor_row: u16
        - cursor_col: u16
        - cursor_visible: bool
        - scroll_top: u16
        - scroll_bottom: u16
        - current_attrs: CellAttrs
        - current_fg: Color
        - current_bg: Color
        - alt_screen: Option<AltScreenState>
        - rows: u16
        - cols: u16
        - tab_stops: Vec<u16>
        - origin_mode: bool
        - auto_wrap: bool
        - wrap_pending: bool
        - saved_cursor: Option<SavedCursor>
        --
        + new(rows: u16, cols: u16) -> Self
        + size() -> (u16, u16)
        + put_char(ch: char)
        + erase_in_line(mode: u16)
        + erase_in_display(mode: u16)
        + scroll_up(count: usize)
        + scroll_down(count: usize)
        + scroll_to_bottom()
        + scroll_view_up(lines: usize)
        + scroll_view_down(lines: usize)
        + set_cursor_position(row: u16, col: u16)
        + reset_attrs()
        + set_bold(val: bool)
        + set_italic(val: bool)
        + set_underline(val: bool)
        + set_strikethrough(val: bool)
        + set_dim(val: bool)
        + set_reverse(val: bool)
        + set_hidden(val: bool)
        + set_fg(color: Color)
        + set_bg(color: Color)
        + save_cursor()
        + restore_cursor()
        + use_alt_screen()
        + use_main_screen()
        + cursor_position() -> (u16, u16)
        + cursor_visible() -> bool
        + visible_rows() -> Vec<Vec<Cell>>
        + visible_window(visible_lines: usize)
        + scroll_offset() -> usize
        + max_scroll_offset() -> usize
        + is_at_bottom() -> bool
        + set_scroll_position(pos: usize)
        + set_visible_lines(count: u16)
        + resize(rows: u16, cols: u16)
    }

    class SavedCursor {
        - row: u16
        - col: u16
        - attrs: CellAttrs
        - fg: Color
        - bg: Color
        - origin_mode: bool
        - auto_wrap: bool
    }

    class AltScreenState {
        - cells: Vec<Vec<Cell>>
        - cursor_row: u16
        - cursor_col: u16
        - saved_cursor: Option<SavedCursor>
    }

    TerminalGrid --> SavedCursor : stores
    TerminalGrid --> AltScreenState : stores option

    note bottom of TerminalGrid
        **Core Terminal State:**
        - Main screen grid [row][col]
        - Scrollback buffer (max 10,000 lines)
        - Cursor position and visibility
        - Scroll region (top/bottom)

        **Rendering State:**
        - Current attributes (bold, italic, etc.)
        - Current foreground/background colors
        - Wrap pending flag
        - Tab stops (every 8 columns)

        **Advanced Features:**
        - Alternate screen buffer (for vim/less)
        - Saved cursor state (DECSC/DECRC)
        - Origin mode (relative to scroll region)
        - Auto-wrap mode
        - Scrollback view with offset tracking

        **Scroll Model:**
        - scroll_offset: 0 = bottom, >0 = scrolled up
        - max_scroll_offset: scrollback.len()
        - visible_rows: current viewport
    end note
}

package "terminal::cell" {
    class Cell {
        + ch: char
        + fg: Color
        + bg: Color
        + attrs: CellAttrs
        --
        + new(ch, fg, bg, attrs) -> Self
        + reset()
    }

    enum Color {
        Named(NamedColor)
        Indexed(u8)
        Rgb(u8, u8, u8)
        --
        + to_egui(is_foreground) -> Color32
        + from_sgr_basic(code: u16) -> Option<Self>
    }

    enum NamedColor {
        Black
        Red
        Green
        Yellow
        Blue
        Magenta
        Cyan
        White
        BrightBlack
        BrightRed
        BrightGreen
        BrightYellow
        BrightBlue
        BrightMagenta
        BrightCyan
        BrightWhite
        Foreground
        Background
    }

    struct CellAttrs {
        + bold: bool
        + italic: bool
        + underline: bool
        + strikethrough: bool
        + dim: bool
        + reverse: bool
        + hidden: bool
        + blink: bool
        --
        + reset()
    }

    Cell --> Color : uses
    Cell --> CellAttrs : uses
    Color --> NamedColor : variants

    note right of Cell
        **Single terminal cell:**
        - Character (Unicode)
        - Foreground color
        - Background color
        - Attributes (bold, underline, etc.)

        **Color support:**
        - Named ANSI (16 colors)
        - 256-color palette
        - True color (24-bit RGB)

        **Attribute support:**
        - Text styles (bold, italic, underline)
        - Display modes (reverse, dim, hidden)
        - Rare features (blink, strikethrough)
    end note
}

' Relationships
TerminalHandler --> TerminalGrid : owns
TerminalGrid --> Cell : contains [row][col]

' Color conversion notes
note bottom of Color
    **Color Conversion:**
    Color → Color32 (egui)
    Uses typical dark terminal theme:
    - Black → RGB(0, 0, 0)
    - Green → RGB(78, 154, 6)
    - Bright Green → RGB(138, 226, 52)

    256-color palette:
    - Indices 0-15: ANSI colors
    - Indices 16-231: 6×6×6 RGB cube
    - Indices 232-255: Grayscale

    SGR codes mapped:
    30-37: foreground colors
    40-47: background colors
    90-97: bright foreground
    100-107: bright background
    38/48: extended colors with sub-params
end note

' Scrolling behavior
note bottom of TerminalGrid
    **Scrolling Architecture:**

    1. **Visible Grid:**
       - Screen-sized grid [row][col]
       - Direct display area

    2. **Scrollback Buffer:**
       - Maintains history (max 10K lines)
       - When line scrolls off top → added to scrollback

    3. **Scroll Position:**
       - scroll_offset = 0: viewing live bottom
       - scroll_offset > 0: viewing history

    4. **Viewport Calculation:**
       - visible_rows() returns slice of current view
       - Based on scroll_offset
       - Combines scrollback + current grid

    5. **User Scrolling:**
       - scroll_view_up/down(): manual scroll
       - Maintains scroll_offset within bounds
       - Max scroll = scrollback.len()

    6. **Auto-scroll:**
       - scroll_to_bottom(): reset scroll_offset to 0
       - Called when new output arrives
       - Can be disabled by manual scroll
end note

@enduml
