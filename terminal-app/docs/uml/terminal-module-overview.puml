@startuml Terminal Module - Component Overview

!define SOLID_FONT_STYLE <font size="12" color="darkblue"><b>
!define SOLID_FONT_STYLE_END </b></font>
!define NOTE_STYLE #e1f5ff

title Terminal Module - Component Overview
' Comprehensive diagram showing all terminal module components and their relationships

package "Terminal Module" {
    ' Core TUI Component
    class TerminalUI {
        - terminal: Terminal<CrosstermBackend>
        - event_polling_paused: Arc<AtomicBool>
        ---
        + new() -> Result<Self>
        + event_polling_pause_flag() -> Arc<AtomicBool>
        + render(state: &mut TerminalState) -> Result<()>
        + clear() -> Result<()>
        + cleanup() -> Result<()>
        + set_window_title(title: &str) -> Result<()>
        + suspend() -> Result<()>
        + resume() -> Result<()>
    }
    note right of TerminalUI
        Facade: wraps ratatui Terminal
        Manages TUI lifecycle:
        - raw mode enable/disable
        - alternate screen enter/leave
        - mouse capture
        Handles interactive command
        suspension/resumption with
        event polling pause flag
    end note

    ' Terminal State Management
    class TerminalState {
        - output: OutputBuffer
        - input: InputBuffer
        - history: CommandHistory
        - mode: TerminalMode
        - pending_interaction: Option<PendingInteraction>
        - visible_lines: usize
        - multiline_buffer: Vec<String>
        - pending_heredoc: Option<String>
        - cached_prompt: String
        - throbber: ThrobberAnimator
        - is_root_mode: bool
        - scrollbar_info: Option<ScrollbarInfo>
        ---
        + new() -> Self
        + add_output(line: String)
        + add_output_lines(lines: Vec<String>)
        + clear_input()
        + submit_input() -> String
        + insert_char(c: char)
        + delete_char()
        + move_cursor_left()
        + move_cursor_right()
        + history_previous()
        + history_next()
        + scroll_up()
        + scroll_down()
        + scroll_to_end()
        + enter_root_mode()
        + exit_root_mode()
        + is_root_mode() -> bool
        + start_throbber()
        + stop_throbber()
        + get_prompt() -> String
        + get_prompt_prefix() -> String
        + refresh_prompt()
        + get_window_title() -> String
        + is_in_hitl_mode() -> bool
        + is_in_multiline_mode() -> bool
    }
    note right of TerminalState
        Composite state container with
        separated responsibilities (SRP):
        - Delegates output to OutputBuffer
        - Delegates input to InputBuffer
        - Delegates history to CommandHistory
        - Delegates animation to ThrobberAnimator
        - Manages interaction state
        - Tracks terminal mode and HITL flow
    end note

    ' Buffer Components (SRP)
    class OutputBuffer {
        - buffer: Vec<String>
        - parsed_buffer: Vec<Line<'static>>
        - scroll_position: usize
        - visible_lines: usize
        - extra_lines: usize
        ---
        + add_line(line: String)
        + add_lines(lines: Vec<String>)
        + scroll_up()
        + scroll_down()
        + scroll_to_end()
        + set_scroll_position(position: usize)
        + scroll_position() -> usize
        + is_at_bottom() -> bool
        + parsed_lines() -> &[Line<'static>]
        + visible_window(height: usize) -> &[Line<'static>]
        + set_visible_lines(lines: usize)
        + pop() -> Option<String>
        + clear()
    }
    note right of OutputBuffer
        SRP: Single responsibility =
        output scrolling and buffering

        Performance optimizations:
        - Caches parsed ANSI -> ratatui Lines
        - Smart auto-scroll when user at bottom
        - Auto-trim when buffer exceeds 10K lines
        - Dual buffer: raw + parsed
    end note

    class InputBuffer {
        - buffer: String
        - cursor_position: usize
        ---
        + insert_char(c: char)
        + delete_char()
        + move_cursor_left()
        + move_cursor_right()
        + clear()
        + set_text(text: String)
        + text() -> &str
        + cursor_position() -> usize
        + take() -> String
    }
    note right of InputBuffer
        SRP: Single responsibility =
        user input management

        Features:
        - Character-based cursor position
        - Unicode-safe (handles multi-byte)
        - Char<->Byte conversion helpers
    end note

    class CommandHistory {
        - history: Vec<String>
        - position: Option<usize>
        ---
        + add(command: String)
        + previous() -> Option<String>
        + next() -> Option<String>
        + reset_position()
        + all() -> &[String]
    }
    note right of CommandHistory
        SRP: Single responsibility =
        command history navigation

        Features:
        - Arrow up/down navigation
        - Skips empty commands
        - Position reset on submit
    end note

    class ThrobberAnimator {
        - index: Arc<AtomicUsize>
        - active: Arc<AtomicBool>
        - thread_handle: Mutex<Option<JoinHandle>>
        ---
        + new() -> Self
        + start()
        + stop()
        + is_running() -> bool
        + symbol() -> &'static str
        + frame_index() -> usize
    }
    note right of ThrobberAnimator
        SRP: Single responsibility =
        loading animation

        Thread Safety:
        - Dedicated animation thread
        - Atomic operations (SeqCst)
        - BRAILLE_DOUBLE symbols at 10 FPS
        - Returns "~" when not running
    end note

    ' Terminal Modes and Types
    enum TerminalMode {
        Normal
        ExecutingCommand
        WaitingLLM
        PromptingInstall
        AwaitingCommandApproval
        AwaitingAnswer
        AwaitingMoreInput(IncompleteReason)
    }
    note right of TerminalMode
        Terminal state machine modes:
        - Normal: awaiting input
        - ExecutingCommand: running shell cmd
        - WaitingLLM: querying LLM backend
        - PromptingInstall: ask to install
        - AwaitingCommandApproval: HITL y/n
        - AwaitingAnswer: HITL free text
        - AwaitingMoreInput: multiline input
    end note

    enum PendingInteraction {
        CommandApproval { command, message, confirmation_type }
        Question { question, options }
    }
    note right of PendingInteraction
        HITL interactions:
        - CommandApproval: user must approve
        - Question: user must answer
        - confirmation_type distinguishes
          shell-originated vs LLM-originated
    end note

    class ScrollbarInfo {
        - column: u16
        - height: u16
        - total_lines: usize
        - visible_lines: usize
        ---
        + is_on_scrollbar(col: u16) -> bool
        + row_to_scroll_position(row: u16) -> usize
    }
    note right of ScrollbarInfo
        Scrollbar position calculation:
        - Used for mouse scrollbar interaction
        - Converts mouse row to scroll position
        - Updated during render_frame
    end note

    ' Event Handler
    class EventHandler {
        ---
        + new() -> Self
        + poll_event(timeout: Duration) -> Result<Option<TerminalEvent>>
        - map_event(event: Event) -> TerminalEvent
        - map_key_event(key: KeyEvent) -> TerminalEvent
        - map_mouse_event(event: MouseEvent) -> TerminalEvent
    }
    note right of EventHandler
        Maps crossterm events to
        custom TerminalEvent enum

        Event types:
        - Key events (chars, arrows, special)
        - Mouse events (scroll, drag, click)
        - Resize events
        - Custom terminal commands

        Windows: filters Release/Repeat events
    end note

    enum TerminalEvent {
        InputChar(char)
        Submit
        DeleteChar
        MoveCursorLeft
        MoveCursorRight
        HistoryPrevious
        HistoryNext
        ScrollUp
        ScrollDown
        TabComplete
        ClearScreen
        CtrlC
        Quit
        Resize(u16, u16)
        MouseDown { column, row }
        MouseDrag { column, row }
        MouseUp
        Unknown
    }
    note right of TerminalEvent
        Custom terminal event enum
        (abstraction over crossterm)

        Keyboard: InputChar, navigation,
                  control commands
        Mouse: scrollbar interaction
        System: resize, quit
    end note

    enum ConfirmationType {
        RmWriteProtected
        RmInteractive { files, current_index, command }
        RmInteractiveBulk { file_count, is_recursive }
        CpInteractive { destination }
        MvInteractive { destination }
        LnInteractive { destination }
    }
    note right of ConfirmationType
        Shell confirmation types:
        Distinguishes shell-originated
        confirmations from LLM-originated

        Used in PendingInteraction.
        CommandApproval to track
        shell-interactive flags
    end note

    ' Relationships
    TerminalUI --> TerminalState : uses >
    TerminalState --> OutputBuffer : composes >
    TerminalState --> InputBuffer : composes >
    TerminalState --> CommandHistory : composes >
    TerminalState --> ThrobberAnimator : composes >
    TerminalState --> TerminalMode : uses >
    TerminalState --> PendingInteraction : uses >
    TerminalState --> ScrollbarInfo : uses >

    EventHandler --> TerminalEvent : produces >
    EventHandler --> TerminalMode : can use >
}

package "External Dependencies" {
    class Terminal #f0f0f0
    class CrosstermBackend #f0f0f0
    class "ratatui Frame" as Frame #f0f0f0
    class "crossterm Event" as CrosstermEvent #f0f0f0
}

TerminalUI --> Terminal : wraps >
TerminalUI --> CrosstermBackend : wraps >
Terminal --> Frame : provides >
EventHandler --> CrosstermEvent : maps from >

note bottom of Terminal
    ratatui Terminal for TUI rendering
    Manages backend, widget drawing
end note

note bottom of Frame
    ratatui Frame object passed to
    render_frame() for drawing widgets
end note

@enduml
