@startuml Terminal - UI and State Management

' ==============================================================================
' Terminal Module
' Shows terminal UI, state management, and event handling
' ==============================================================================

skinparam class {
    BackgroundColor White
    BorderColor Black
}

' ==============================================================================
' Terminal UI
' ==============================================================================

class TerminalUI {
    - terminal: Terminal<CrosstermBackend<io::Stdout>>
    __
    <b>Construction & Cleanup</b>
    + new(): Result<Self>
    + cleanup(&mut self): Result<()>
    __
    <b>Rendering</b>
    + render(&mut self, state: &TerminalState): Result<()>
    + clear(&mut self): Result<()>
}

note right of TerminalUI
  <b>TUI Implementation</b>

  Stack:
  - ratatui: Terminal UI framework
  - crossterm: Terminal backend

  Rendering components:
  - Output area (scrollable)
  - Input line with cursor
  - Status bar (mode indicator)

  Uses TerminalState for data
  Stateless rendering
end note

' ==============================================================================
' Terminal State
' ==============================================================================

class TerminalState {
    + output_buffer: Vec<String>
    + input_buffer: String
    + mode: TerminalMode
    + cursor_position: usize
    + command_history: Vec<String>
    + history_position: Option<usize>
    + scroll_position: usize
    __
    <b>Construction</b>
    + new(): Self
    __
    <b>Output Management</b>
    + add_output(&mut self, line: String)
    + add_output_lines(&mut self, lines: Vec<String>)
    __
    <b>Input Management</b>
    + clear_input(&mut self)
    + submit_input(&mut self): String
    + insert_char(&mut self, c: char)
    + delete_char(&mut self)
    __
    <b>Cursor Movement</b>
    + move_cursor_left(&mut self)
    + move_cursor_right(&mut self)
    __
    <b>History Navigation</b>
    + history_previous(&mut self)
    + history_next(&mut self)
    __
    <b>Scrolling</b>
    + scroll_up(&mut self)
    + scroll_down(&mut self)
}

enum TerminalMode {
    <b>Normal</b>
    Waiting for input
    __
    <b>ExecutingCommand</b>
    Running shell command
    __
    <b>WaitingLLM</b>
    Querying LLM backend
    __
    <b>PromptingInstall</b>
    Asking to install missing command
    (M2/M3 feature)
}

TerminalState o-- TerminalMode
TerminalUI ..> TerminalState : <<renders>>

note left of TerminalState
  <b>Buffer Management</b>

  Constants:
  - MAX_OUTPUT_LINES: 10,000
  - TRIM_LINES: 1,000

  When buffer exceeds max:
  - Remove oldest TRIM_LINES
  - Adjust scroll_position
  - Prevent memory growth

  Performance optimization:
  add_output_lines() uses extend()
  for better performance
end note

note bottom of TerminalMode
  <b>Mode Indicators</b>

  Visualizzato nella status bar:

  Normal: "Ready"
  ExecutingCommand: "Executing..."
  WaitingLLM: "Querying AI..."
  PromptingInstall: "Install?"

  Determina comportamento UI
end note

' ==============================================================================
' Event Handling
' ==============================================================================

class EventHandler {
    __
    <b>Construction</b>
    + new(): Self
    __
    <b>Event Polling</b>
    + poll_event(&self, timeout: Duration): Result<Option<TerminalEvent>>
    __
    <b>Internal Mapping</b>
    - map_event(&self, event: Event): TerminalEvent
    - map_key_event(&self, key: KeyEvent): TerminalEvent
}

enum TerminalEvent {
    <b>Text Input</b>
    InputChar(char)
    __
    <b>Commands</b>
    Submit
    DeleteChar
    TabComplete
    ClearScreen
    Quit
    __
    <b>Navigation</b>
    MoveCursorLeft
    MoveCursorRight
    HistoryPrevious
    HistoryNext
    ScrollUp
    ScrollDown
    __
    <b>System</b>
    Resize(u16, u16)
    Unknown
}

EventHandler ..> TerminalEvent : <<creates>>

note right of EventHandler
  <b>Keyboard Mappings</b>

  <b>Text:</b>
  Any printable char → InputChar(c)

  <b>Editing:</b>
  Enter → Submit
  Backspace → DeleteChar
  Tab → TabComplete
  Ctrl+L → ClearScreen

  <b>Movement:</b>
  Left arrow → MoveCursorLeft
  Right arrow → MoveCursorRight
  Up arrow → HistoryPrevious
  Down arrow → HistoryNext
  PageUp → ScrollUp
  PageDown → ScrollDown

  <b>Control:</b>
  Ctrl+C → Quit
  Ctrl+D → Quit
end note

note bottom of TerminalEvent
  <b>Event Loop Flow</b>

  1. EventHandler::poll_event(100ms)
  2. Crossterm event → TerminalEvent
  3. InfrawareTerminal::handle_event()
  4. Update TerminalState
  5. TerminalUI::render(&state)
  6. Loop
end note

' ==============================================================================
' Relationships
' ==============================================================================

package "Used by Main Application" {
    class InfrawareTerminal {
        - ui: TerminalUI
        - state: TerminalState
        - event_handler: EventHandler
    }
}

InfrawareTerminal *-- TerminalUI
InfrawareTerminal *-- TerminalState
InfrawareTerminal *-- EventHandler
InfrawareTerminal ..> TerminalEvent : <<handles>>

@enduml
