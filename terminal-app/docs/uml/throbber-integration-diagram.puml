@startuml ThrobberAnimator Integration Diagram
!theme plain
title "ThrobberAnimator Integration in TerminalState"

package "terminal::state" {
    class TerminalState {
        - output: OutputBuffer
        - input: InputBuffer
        - history: CommandHistory
        - mode: TerminalMode
        - pending_interaction: Option<PendingInteraction>
        - visible_lines: usize
        - multiline_buffer: Vec<String>
        - pending_heredoc: Option<String>
        - cached_prompt: String
        - throbber: ThrobberAnimator
        - is_root_mode: bool

        + new() -> Self
        + start_throbber() -> void
        + stop_throbber() -> void
        + get_prompt_prefix() -> String
        + get_prompt() -> String
        + refresh_prompt() -> void
        + enter_root_mode() -> void
        + exit_root_mode() -> void
        ...other methods
    }

    enum TerminalMode {
        Normal
        ExecutingCommand
        WaitingLLM
        PromptingInstall
        AwaitingCommandApproval
        AwaitingAnswer
        AwaitingMoreInput(IncompleteReason)
    }
}

package "terminal::throbber" {
    class ThrobberAnimator {
        - index: Arc<AtomicUsize>
        - active: Arc<AtomicBool>
        - thread_handle: Mutex<Option<JoinHandle<()>>>

        + new() -> Self
        + start() -> void
        + stop() -> void
        + is_running() -> bool
        + symbol() -> &'static str
        + frame_index() -> usize
    }
}

package "terminal::tui" {
    class TerminalUI {
        - terminal: Terminal<CrosstermBackend<io::Stdout>>
        - event_polling_paused: Arc<AtomicBool>

        + new() -> Result<Self>
        + render(&mut self, state: &mut TerminalState) -> Result<()>
        + suspend() -> Result<()>
        + resume() -> Result<()>
    }
}

' Relationships
TerminalState --> ThrobberAnimator : contains
TerminalState --> TerminalMode : uses

note right of TerminalState
  get_prompt_prefix():
  - If WaitingLLM mode AND throbber.is_running()
    return "|<throbber.symbol()>|"
  - Otherwise return "|~|"

  This creates animated prompt:
  |⠋| $ → |⠙| $ → |⠹| $ → ...
end note

note on link TerminalState, TerminalUI
  UI queries state.get_prompt_prefix()
  during render() to display animated
  loading indicator in the prompt area
end note

note right of TerminalMode
  WaitingLLM mode:
  - Throbber should be running
  - Used during NLM query execution
  - Prompt prefix shows animation
end note

@enduml
