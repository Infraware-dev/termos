@startuml "SCAN Algorithm - 10-Handler Chain of Responsibility"
title "SCAN Algorithm: Chain of Responsibility with 10 Handlers (Optimized Performance)"

' ==================== CORE INTERFACES ====================

interface InputHandler <<interface>> {
  + handle(input: &str): Option<InputType>
}

class InputType <<enum>> {
  Command { command, args, original_input }
  NaturalLanguage(String)
  Empty
  CommandTypo { input, suggestion, distance }
}

' ==================== CHAIN COORDINATOR ====================

class ClassifierChain {
  - handlers: Vec<Box<dyn InputHandler>>
  --
  + new(): Self
  + add_handler(Box<dyn InputHandler>): Self
  + process(input: &str): Option<InputType>
}

impl std::fmt::Debug for ClassifierChain {
  note right
    **Microsoft Rust Guidelines**
    Now implements Debug trait
    Returns handler count instead
    of full handler list
  end note
}

class InputClassifier {
  - chain: ClassifierChain
  - history: Option<Arc<RwLock<Vec<String>>>>
  --
  + new(): Self
  + with_history(history): Self
  + classify(input): Result<InputType>
  - classify_internal(input): Result<InputType>
}

impl std::fmt::Debug for InputClassifier {
  note right
    **Microsoft Rust Guidelines**
    Now implements Debug trait
    Prints chain reference only
  end note
}

' ==================== HANDLER 1: EMPTY INPUT ====================

class EmptyInputHandler {
  + new(): Self
  --
  + handle(input): Option<InputType>
}

EmptyInputHandler ..|> InputHandler

note right of EmptyInputHandler
  **Handler 1: Empty Input** (<1μs)
  Fast path for empty/whitespace
  Returns: InputType::Empty
end note

' ==================== HANDLER 2: HISTORY EXPANSION ====================

class HistoryExpansionHandler {
  - history: Option<Arc<RwLock<Vec<String>>>>
  --
  + new(): Self
  + with_history(history): Self
  + handle(input): Option<InputType>
  - expand_history(input): Option<String>
}

HistoryExpansionHandler ..|> InputHandler

note right of HistoryExpansionHandler
  **Handler 2: History Expansion** (1-5μs)
  Bash-style: !!, !$, !^, !*
  Thread-safe via Arc<RwLock>
  Must happen before parsing
end note

' ==================== HANDLER 3: APPLICATION BUILTINS ====================

class ApplicationBuiltinHandler {
  + new(): Self
  --
  + handle(input): Option<InputType>
}

ApplicationBuiltinHandler ..|> InputHandler

note right of ApplicationBuiltinHandler
  **Handler 3: Application Builtins** (<1μs)
  - clear: Clear output buffer
  - reload-aliases: Reload shell aliases
  - reload-commands: Clear command cache
  High priority to prevent misclassification
end note

' ==================== HANDLER 4: SHELL BUILTINS ====================

class ShellBuiltinHandler {
  + new(): Self
  --
  + is_shell_builtin(cmd): bool
  + requires_shell_execution(cmd): bool
  + handle(input): Option<InputType>
}

ShellBuiltinHandler ..|> InputHandler

note right of ShellBuiltinHandler
  **Handler 4: Shell Builtins** (<1μs)
  45+ builtins: ., :, [, [[, export
  eval, exec, source, etc.
  No PATH verification needed
  ShellBuiltinInfo provides metadata
end note

' ==================== HANDLER 5: PATH COMMANDS ====================

class PathCommandHandler {
  + new(): Self
  --
  + is_path(input): bool
  + handle(input): Option<InputType>
}

PathCommandHandler ..|> InputHandler

note right of PathCommandHandler
  **Handler 5: Path Commands** (~10μs)
  ./script.sh, /usr/bin/cmd
  Unambiguous executable detection
  Detects both relative and absolute
end note

' ==================== HANDLER 6: KNOWN COMMANDS ====================

class KnownCommandHandler {
  - known_commands: Vec<String>
  --
  + new(commands): Self
  + with_defaults(): Self
  + is_known_command(input): bool
  + handle(input): Option<InputType>
}

impl std::fmt::Debug for KnownCommandHandler {
  note right
    **Microsoft Rust Guidelines**
    Now implements Debug trait
    Returns count of known commands
  end note
}

KnownCommandHandler ..|> InputHandler

note right of KnownCommandHandler
  **Handler 6: Known Commands** (<1μs hit)
  60+ DevOps commands verified
  Uses CommandCache for O(1) PATH lookups
  Supports caching + poisoning recovery
  First hit cached, misses added to unavailable
end note

' ==================== HANDLER 7: COMMAND SYNTAX ====================

class CommandSyntaxHandler {
  + new(): Self
  --
  + looks_like_command(input): bool
  + handle(input): Option<InputType>
}

CommandSyntaxHandler ..|> InputHandler

note right of CommandSyntaxHandler
  **Handler 7: Command Syntax** (~10μs)
  Detects: flags (--flag), pipes, redirects
  Env vars ($VAR), paths (/, ./, ../)
  Language-agnostic: uses RegexSet
  Precompiled patterns for speed
end note

' ==================== HANDLER 8: TYPO DETECTION ====================

class TypoDetectionHandler {
  - known_commands: Vec<String>
  - max_distance: usize
  --
  + new(commands, max_distance): Self
  + with_defaults(): Self
  + find_closest_match(input): Option<(String, usize)>
  + handle(input): Option<InputType>
}

TypoDetectionHandler ..|> InputHandler

note right of TypoDetectionHandler
  **Handler 8: Typo Detection** (~100μs)
  Levenshtein distance ≤ 2
  Prevents misclassification:
  - "dokcer" → "docker"
  - "kubeclt" → "kubectl"
  Filters 5+ word phrases (natural language)
end note

' ==================== HANDLER 9: NATURAL LANGUAGE ====================

class NaturalLanguageHandler {
  + new(): Self
  --
  + is_likely_natural_language(input): bool
  + handle(input): Option<InputType>
}

NaturalLanguageHandler ..|> InputHandler

note right of NaturalLanguageHandler
  **Handler 9: Natural Language** (~0.5μs)
  Language-agnostic heuristics:
  - Universal punctuation (?!, .., commas)
  - Non-ASCII detection (accents, unicode)
  - Word count analysis (>5 words)
  - Articles detection (the, a, un, el)
  - Contractions (don't, can't)
  - English-only fallback patterns
end note

' ==================== HANDLER 10: DEFAULT ====================

class DefaultHandler {
  + new(): Self
  --
  + handle(input): Option<InputType>
}

DefaultHandler ..|> InputHandler

note right of DefaultHandler
  **Handler 10: Default** (<1μs)
  Fallback: Treat as natural language
  Ensures no input passes unclassified
end note

' ==================== CHAIN ASSEMBLY ====================

package "Chain Execution Order (Optimized)" {
  rectangle "H1: Empty\n(<1μs)" as h1 #F0F0FF
  rectangle "H2: History\n(1-5μs)" as h2 #F0F0FF
  rectangle "H3: AppBuiltin\n(<1μs)" as h3 #E0E0FF
  rectangle "H4: ShellBuiltin\n(<1μs)" as h4 #E0E0FF
  rectangle "H5: PathCmd\n(~10μs)" as h5 #D0D0FF
  rectangle "H6: KnownCmd\n(<1μs)" as h6 #C0C0FF
  rectangle "H7: CmdSyntax\n(~10μs)" as h7 #B0B0FF
  rectangle "H8: TypoDetect\n(~100μs)" as h8 #A0A0FF
  rectangle "H9: NatLang\n(~0.5μs)" as h9 #9090FF
  rectangle "H10: Default\n(<1μs)" as h10 #8080FF

  h1 --> h2 : None
  h2 --> h3 : None
  h3 --> h4 : None
  h4 --> h5 : None
  h5 --> h6 : None
  h6 --> h7 : None
  h7 --> h8 : None
  h8 --> h9 : None
  h9 --> h10 : None
}

' Relationships
ClassifierChain --> InputHandler : contains 10×
InputClassifier --> ClassifierChain : coordinates
InputClassifier --> InputType : returns
KnownCommandHandler --> "CommandCache" : verifies via
TypoDetectionHandler --> "Levenshtein" : uses

' Performance notes
note top of ClassifierChain
  **Design Pattern: Chain of Responsibility**
  - Each handler can classify or pass to next
  - Order critical: fast paths first
  - Performance target: <100μs average

  **Performance Optimizations**
  - Precompiled RegexSet (patterns.rs)
  - Thread-safe CommandCache with RwLock
  - Poisoning recovery for cache safety
  - Short-circuit evaluation
  - LazyLock for global pattern instance
end note

@enduml
