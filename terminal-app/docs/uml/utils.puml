@startuml Utils - Formatting and Error Handling

' ==============================================================================
' Utils Module
' Shows message formatting, ANSI colors, and error types
' ==============================================================================

skinparam class {
    BackgroundColor White
    BorderColor Black
}

' ==============================================================================
' Message Formatting
' ==============================================================================

class MessageFormatter {
    __
    <b>Message Types</b>
    + {static} error(message: impl AsRef<str>): String
    + {static} warning(message: impl AsRef<str>): String
    + {static} success(message: impl AsRef<str>): String
    + {static} info(message: impl AsRef<str>): String
    + {static} command(message: impl AsRef<str>): String
    + {static} question(message: impl AsRef<str>): String
    + {static} suggestion(message: impl AsRef<str>): String
    __
    <b>Generic Formatter</b>
    + {static} format(msg_type: MessageType, message: impl AsRef<str>): String
    __
    <b>Specialized Messages</b>
    + {static} command_not_found(cmd: impl AsRef<str>): String
    + {static} command_failed(exit_code: i32): String
    + {static} execution_error(error: impl AsRef<str>): String
    + {static} install_suggestion(available: bool): String
    __
    <b>Banner Formatting</b>
    + {static} banner_line(content: impl AsRef<str>): String
    + {static} banner_hint(content: impl AsRef<str>): String
    __
    <b>Stderr Formatting</b>
    + {static} stderr_error(line: impl AsRef<str>): String
}

enum MessageType {
    Error
    Warning
    Success
    Info
    Command
    Question
}

MessageFormatter ..> MessageType : <<uses>>
MessageFormatter ..> AnsiColor : <<uses>>

note top of MessageFormatter
  <b>Centralized Message Formatting</b>

  Ensures consistent output styling:

  ✗ Error (red)
  ⚠ Warning (yellow)
  ✓ Success (green)
  ℹ Info (blue)
  ❯ Command (cyan)
  ? Question (magenta)
  → Suggestion (yellow)

  All messages use ANSI colors
  for terminal-friendly output
end note

' ==============================================================================
' ANSI Colors
' ==============================================================================

enum AnsiColor {
    <b>Standard Colors</b>
    Black, Red, Green, Yellow
    Blue, Magenta, Cyan, White
    __
    <b>Bright Colors</b>
    BrightBlack, BrightRed, BrightGreen, BrightYellow
    BrightBlue, BrightMagenta, BrightCyan, BrightWhite
    __
    <b>Special</b>
    Reset
    __
    + code(): &'static str
    + colorize(&self, text: &str): String
}

class AnsiStyle {
    {static} + BOLD: &str
    {static} + DIM: &str
    {static} + ITALIC: &str
    {static} + UNDERLINE: &str
    {static} + BLINK: &str
    {static} + REVERSE: &str
    {static} + HIDDEN: &str
    {static} + STRIKETHROUGH: &str
    {static} + RESET: &str
    __
    + {static} bold(text: &str): String
    + {static} dim(text: &str): String
    + {static} italic(text: &str): String
    + {static} underline(text: &str): String
}

note right of AnsiColor
  <b>ANSI Escape Codes</b>

  Examples:
  - Red: \\e[31m
  - Green: \\e[32m
  - Bold: \\e[1m
  - Reset: \\e[0m

  colorize() wraps text:
  "{color_code}{text}\\e[0m"

  Utility:
  strip_ansi_codes(text) → plain text
end note

note bottom of AnsiStyle
  <b>Text Styling</b>

  bold("text") → "\\e[1mtext\\e[0m"

  Combinable with colors:
  AnsiColor::Red.colorize(
    AnsiStyle::bold("Error")
  )
end note

' ==============================================================================
' Error Handling
' ==============================================================================

enum InfraError {
    <b>I/O Errors</b>
    Io(std::io::Error)
    __
    <b>Command Errors</b>
    CommandExecution(String)
    CommandNotFound(String)
    __
    <b>LLM Errors</b>
    LLMRequest(String)
    Network(reqwest::Error)
    __
    <b>Parsing Errors</b>
    Parse(String)
    __
    <b>UI Errors</b>
    TerminalUI(String)
    __
    <b>Installation Errors</b>
    PackageInstall(String)
    NoPackageManager
    __
    <b>Configuration Errors</b>
    Config(String)
    __
    <b>Generic Errors</b>
    Generic(String)
    Other(anyhow::Error)
    __
    <b>Constructors</b>
    + command_execution(msg: impl Into<String>): Self
    + command_not_found(cmd: impl Into<String>): Self
    + llm_request(msg: impl Into<String>): Self
    + parse(msg: impl Into<String>): Self
    + terminal_ui(msg: impl Into<String>): Self
    + package_install(msg: impl Into<String>): Self
    + config(msg: impl Into<String>): Self
    + generic(msg: impl Into<String>): Self
    __
    <b>Utilities</b>
    + is_command_not_found(): bool
    + message(): String
}

note top of InfraError
  <b>Error Handling with thiserror</b>

  Custom error type che implementa:
  - std::error::Error
  - Display
  - From conversions

  Type alias:
  type InfraResult<T> = Result<T, InfraError>

  Usato quando serve error type specifico,
  altrimenti si usa anyhow::Result
end note

note bottom of InfraError
  <b>Error Contexts</b>

  <b>I/O:</b> File operations, terminal init

  <b>Command:</b> Execution failures, missing commands

  <b>LLM:</b> API errors, network issues

  <b>Parse:</b> Command parsing, config parsing

  <b>UI:</b> Terminal rendering errors

  <b>Install:</b> Package installation failures

  <b>Config:</b> Configuration errors

  Ogni variante ha helper constructor
  per creazione ergonomica
end note

' ==============================================================================
' Usage Examples
' ==============================================================================

package "Used Throughout Application" {
    class CommandOrchestrator
    class NaturalLanguageOrchestrator
    class TerminalUI
    class InputClassifier
}

CommandOrchestrator ..> MessageFormatter : <<uses>>
NaturalLanguageOrchestrator ..> MessageFormatter : <<uses>>
TerminalUI ..> AnsiColor : <<uses>>
InputClassifier ..> InfraError : <<throws>>

@enduml
