@startuml Infraware Terminal - Complete Class Diagram

' ==============================================================================
' Infraware Terminal - Complete UML Class Diagram
' ==============================================================================
' This diagram shows the complete architecture of the Infraware Terminal
' with all classes, relationships, and design patterns highlighted.
' ==============================================================================

!define BUILDER_COLOR #FFFACD
!define STRATEGY_COLOR #90EE90
!define CHAIN_COLOR #87CEEB
!define FACADE_COLOR #DDA0DD
!define ORCHESTRATOR_COLOR #FFB366

skinparam class {
    BackgroundColor White
    BorderColor Black
    ArrowColor Black
}

skinparam stereotypeCBackgroundColor Yellow

' ==============================================================================
' MAIN APPLICATION (Builder Pattern)
' ==============================================================================

package "Main Application" <<Rectangle>> {

    class InfrawareTerminal {
        - ui: TerminalUI
        - state: TerminalState
        - classifier: InputClassifier
        - event_handler: EventHandler
        - command_orchestrator: CommandOrchestrator
        - nl_orchestrator: NaturalLanguageOrchestrator
        - tab_completion_handler: TabCompletionHandler
        __
        + builder(): InfrawareTerminalBuilder
        + new(): Result<Self>
        + new_with_client(llm_client: Arc<dyn LLMClientTrait>): Result<Self>
        + {async} run(&mut self): Result<()>
        - {async} handle_event(&mut self, event: TerminalEvent): Result<bool>
        - {async} handle_submit(&mut self): Result<()>
        - {async} handle_command(&mut self, cmd: &str, args: &[String]): Result<()>
        - {async} handle_natural_language(&mut self, query: &str): Result<()>
        - handle_tab_completion(&mut self)
    }

    class InfrawareTerminalBuilder <<Builder>> BUILDER_COLOR {
        - ui: Option<TerminalUI>
        - state: Option<TerminalState>
        - classifier: Option<InputClassifier>
        - event_handler: Option<EventHandler>
        - llm_client: Option<Arc<dyn LLMClientTrait>>
        - renderer: Option<ResponseRenderer>
        - command_orchestrator: Option<CommandOrchestrator>
        - tab_completion_handler: Option<TabCompletionHandler>
        __
        + new(): Self
        + with_ui(ui: TerminalUI): Self
        + with_state(state: TerminalState): Self
        + with_classifier(classifier: InputClassifier): Self
        + with_event_handler(event_handler: EventHandler): Self
        + with_llm_client(client: Arc<dyn LLMClientTrait>): Self
        + with_renderer(renderer: ResponseRenderer): Self
        + build(): Result<InfrawareTerminal>
    }

    InfrawareTerminalBuilder ..> InfrawareTerminal : <<builds>>
}

' ==============================================================================
' ORCHESTRATORS (Orchestrator Pattern)
' ==============================================================================

package "Orchestrators" <<Rectangle>> {

    class CommandOrchestrator <<Orchestrator>> ORCHESTRATOR_COLOR {
        __
        + new(): Self
        + {async} handle_command(&self, cmd: &str, args: &[String], \n    state: &mut TerminalState, ui: &mut TerminalUI): Result<()>
        - handle_clear_command(&self, state: &mut TerminalState, \n    ui: &mut TerminalUI): Result<()>
        - handle_command_not_found(&self, cmd: &str, \n    state: &mut TerminalState)
        - {async} execute_and_display(&self, cmd: &str, args: &[String], \n    state: &mut TerminalState): Result<()>
    }

    class NaturalLanguageOrchestrator <<Orchestrator>> ORCHESTRATOR_COLOR {
        - llm_client: Arc<dyn LLMClientTrait>
        - renderer: ResponseRenderer
        __
        + new(llm_client: Arc<dyn LLMClientTrait>, \n    renderer: ResponseRenderer): Self
        + {async} handle_query(&self, query: &str, \n    state: &mut TerminalState, ui: &mut TerminalUI): Result<()>
        - handle_success(&self, response: String, \n    state: &mut TerminalState)
        - handle_error(&self, error: anyhow::Error, \n    state: &mut TerminalState)
    }

    class TabCompletionHandler <<Orchestrator>> ORCHESTRATOR_COLOR {
        __
        + new(): Self
        + handle_tab_completion(&self, state: &mut TerminalState)
        - handle_single_completion(&self, completion: &str, \n    state: &mut TerminalState)
        - handle_multiple_completions(&self, completions: &[String], \n    input: &str, state: &mut TerminalState)
    }
}

' ==============================================================================
' EXECUTOR MODULE (Facade & Strategy Patterns)
' ==============================================================================

package "Executor" <<Rectangle>> {

    class CommandExecutor {
        __
        + {async} {static} execute(cmd: &str, args: &[String]): Result<CommandOutput>
        + {static} command_exists(cmd: &str): bool
        + {static} get_command_path(cmd: &str): Option<String>
        + {async} {static} execute_sudo(cmd: &str, args: &[String]): Result<CommandOutput>
    }

    class CommandOutput {
        + stdout: String
        + stderr: String
        + exit_code: i32
        __
        + is_success(): bool
        + combined_output(): String
    }

    class CommandExecutionFacade <<Facade>> FACADE_COLOR {
        - installer: PackageInstaller
        __
        + new(): Self
        + with_installer(installer: PackageInstaller): Self
        + {async} execute_with_fallback(&self, cmd: &str, \n    args: &[String]): Result<ExecutionResult>
        + {async} execute_or_install(&self, cmd: &str, args: &[String], \n    auto_install: bool): Result<ExecutionResult>
        + is_command_available(&self, cmd: &str): bool
        + can_install_packages(&self): bool
        + get_package_manager(&self): Option<&str>
    }

    enum ExecutionResult {
        Success(CommandOutput)
        CommandNotFound { command: String, can_install: bool, package_manager: Option<String> }
        ExecutionError { command: String, error: String }
        __
        + is_success(): bool
        + output(): Option<&CommandOutput>
        + error_message(): Option<String>
    }

    interface PackageManager <<Strategy>> STRATEGY_COLOR {
        + name(): &str
        + is_available(): bool
        + {async} install(package: &str): Result<()>
        + priority(): u8
    }

    class AptPackageManager <<Strategy>> STRATEGY_COLOR
    class YumPackageManager <<Strategy>> STRATEGY_COLOR
    class DnfPackageManager <<Strategy>> STRATEGY_COLOR
    class PacmanPackageManager <<Strategy>> STRATEGY_COLOR
    class BrewPackageManager <<Strategy>> STRATEGY_COLOR
    class ChocoPackageManager <<Strategy>> STRATEGY_COLOR
    class WingetPackageManager <<Strategy>> STRATEGY_COLOR

    class PackageInstaller {
        - managers: Vec<Box<dyn PackageManager>>
        __
        + new(): Self
        + with_managers(managers: Vec<Box<dyn PackageManager>>): Self
        + register(&mut self, manager: Box<dyn PackageManager>)
        + {async} install_package(&self, package: &str): Result<()>
        - select_package_manager(&self): Result<&dyn PackageManager>
        + is_available(&self): bool
        + get_package_manager(&self): Option<&str>
        + get_available_managers(&self): Vec<&str>
        + {async} {static} install_package_static(package: &str): Result<()>
        + {static} is_available_static(): bool
        + {static} get_package_manager_static(): Option<String>
    }

    class TabCompletion {
        __
        + {static} get_completions(partial: &str): Vec<String>
        - {static} complete_command(partial: &str): Vec<String>
        - {static} complete_file_path(partial: &str): Vec<String>
        + {static} get_common_prefix(completions: &[String]): String
    }

    PackageManager <|.. AptPackageManager
    PackageManager <|.. YumPackageManager
    PackageManager <|.. DnfPackageManager
    PackageManager <|.. PacmanPackageManager
    PackageManager <|.. BrewPackageManager
    PackageManager <|.. ChocoPackageManager
    PackageManager <|.. WingetPackageManager

    PackageInstaller o-- PackageManager
    CommandExecutionFacade *-- PackageInstaller
    CommandExecutor ..> CommandOutput : <<creates>>
    CommandExecutionFacade ..> ExecutionResult : <<creates>>
    ExecutionResult o-- CommandOutput
}

' ==============================================================================
' INPUT MODULE (Chain of Responsibility Pattern)
' ==============================================================================

package "Input Classification" <<Rectangle>> {

    class InputClassifier {
        - chain: ClassifierChain
        __
        + new(): Self
        + with_chain(chain: ClassifierChain): Self
        + classify(&self, input: &str): Result<InputType>
        + {deprecated} add_known_command(&mut self, command: String)
    }

    enum InputType {
        Command(String, Vec<String>)
        NaturalLanguage(String)
        Empty
    }

    class ClassifierChain <<Chain>> CHAIN_COLOR {
        - handlers: Vec<Box<dyn InputHandler>>
        __
        + new(): Self
        + add_handler(handler: Box<dyn InputHandler>): Self
        + process(&self, input: &str): Option<InputType>
        + len(): usize
        + is_empty(): bool
    }

    interface InputHandler <<Chain>> CHAIN_COLOR {
        + handle(&self, input: &str): Option<InputType>
        + name(): &str
    }

    class EmptyInputHandler <<Handler>> CHAIN_COLOR {
        + new(): Self
    }

    class KnownCommandHandler <<Handler>> CHAIN_COLOR {
        - known_commands: Vec<String>
        __
        + new(known_commands: Vec<String>): Self
        + with_defaults(): Self
        - default_known_commands(): Vec<String>
        - is_known_command(&self, input: &str): bool
        - parse_as_command(&self, input: &str): Result<InputType>
        + add_command(&mut self, command: String)
    }

    class CommandSyntaxHandler <<Handler>> CHAIN_COLOR {
        + new(): Self
        - looks_like_command(&self, input: &str): bool
        - parse_as_command(&self, input: &str): Result<InputType>
    }

    class NaturalLanguageHandler <<Handler>> CHAIN_COLOR {
        + new(): Self
        - is_likely_natural_language(&self, input: &str): bool
        - has_command_syntax(&self, input: &str): bool
    }

    class DefaultHandler <<Handler>> CHAIN_COLOR {
        + new(): Self
    }

    class CommandParser {
        __
        + {static} parse(input: &str): Result<(String, Vec<String>)>
        + {static} quote_if_needed(arg: &str): String
        + {static} join(command: &str, args: &[String]): String
    }

    InputHandler <|.. EmptyInputHandler
    InputHandler <|.. KnownCommandHandler
    InputHandler <|.. CommandSyntaxHandler
    InputHandler <|.. NaturalLanguageHandler
    InputHandler <|.. DefaultHandler

    ClassifierChain o-- InputHandler
    InputClassifier *-- ClassifierChain
    InputClassifier ..> InputType : <<creates>>
    ClassifierChain ..> InputType : <<creates>>
}

' ==============================================================================
' LLM MODULE (Strategy Pattern)
' ==============================================================================

package "LLM" <<Rectangle>> {

    interface LLMClientTrait <<Strategy>> STRATEGY_COLOR {
        + {async} query(&self, text: &str): Result<String>
        + {async} query_with_context(&self, text: &str, \n    context: Option<String>): Result<String>
        + {async} query_with_history(&self, text: &str, \n    command_history: &[String]): Result<String>
    }

    class HttpLLMClient <<Strategy>> STRATEGY_COLOR {
        - base_url: String
        - client: reqwest::Client
        __
        + new(base_url: String): Self
        + with_timeout(base_url: String, timeout_secs: u64): Result<Self>
    }

    class MockLLMClient <<Strategy>> STRATEGY_COLOR {
        + new(): Self
    }

    class LLMRequest {
        + query: String
        + context: Option<String>
    }

    class LLMResponse {
        + text: String
        + metadata: Option<serde_json::Value>
    }

    class ResponseRenderer {
        - syntax_set: SyntaxSet
        - theme_set: ThemeSet
        __
        + new(): Self
        + render(&self, text: &str): Vec<String>
        - format_inline(&self, line: &str): String
        - highlight_code(&self, lines: &[String], lang: &str): Vec<String>
    }

    LLMClientTrait <|.. HttpLLMClient
    LLMClientTrait <|.. MockLLMClient
    HttpLLMClient ..> LLMRequest : <<uses>>
    HttpLLMClient ..> LLMResponse : <<uses>>
}

' ==============================================================================
' TERMINAL MODULE
' ==============================================================================

package "Terminal" <<Rectangle>> {

    class TerminalUI {
        - terminal: Terminal<CrosstermBackend<io::Stdout>>
        __
        + new(): Result<Self>
        + render(&mut self, state: &TerminalState): Result<()>
        + clear(&mut self): Result<()>
        + cleanup(&mut self): Result<()>
    }

    class TerminalState {
        + output_buffer: Vec<String>
        + input_buffer: String
        + mode: TerminalMode
        + cursor_position: usize
        + command_history: Vec<String>
        + history_position: Option<usize>
        + scroll_position: usize
        __
        + new(): Self
        + add_output(&mut self, line: String)
        + add_output_lines(&mut self, lines: Vec<String>)
        + clear_input(&mut self)
        + submit_input(&mut self): String
        + insert_char(&mut self, c: char)
        + delete_char(&mut self)
        + move_cursor_left(&mut self)
        + move_cursor_right(&mut self)
        + history_previous(&mut self)
        + history_next(&mut self)
        + scroll_up(&mut self)
        + scroll_down(&mut self)
    }

    enum TerminalMode {
        Normal
        ExecutingCommand
        WaitingLLM
        PromptingInstall
    }

    class EventHandler {
        __
        + new(): Self
        + poll_event(&self, timeout: Duration): Result<Option<TerminalEvent>>
        - map_event(&self, event: Event): TerminalEvent
        - map_key_event(&self, key: KeyEvent): TerminalEvent
    }

    enum TerminalEvent {
        InputChar(char)
        Submit
        DeleteChar
        MoveCursorLeft
        MoveCursorRight
        HistoryPrevious
        HistoryNext
        ScrollUp
        ScrollDown
        TabComplete
        ClearScreen
        Quit
        Resize(u16, u16)
        Unknown
    }

    TerminalState o-- TerminalMode
    TerminalUI ..> TerminalState : <<uses>>
    EventHandler ..> TerminalEvent : <<creates>>
}

' ==============================================================================
' UTILS MODULE
' ==============================================================================

package "Utils" <<Rectangle>> {

    class MessageFormatter {
        __
        + {static} error(message: impl AsRef<str>): String
        + {static} warning(message: impl AsRef<str>): String
        + {static} success(message: impl AsRef<str>): String
        + {static} info(message: impl AsRef<str>): String
        + {static} command(message: impl AsRef<str>): String
        + {static} question(message: impl AsRef<str>): String
        + {static} suggestion(message: impl AsRef<str>): String
        + {static} format(msg_type: MessageType, message: impl AsRef<str>): String
        + {static} command_not_found(cmd: impl AsRef<str>): String
        + {static} command_failed(exit_code: i32): String
        + {static} execution_error(error: impl AsRef<str>): String
        + {static} install_suggestion(available: bool): String
        + {static} banner_line(content: impl AsRef<str>): String
        + {static} banner_hint(content: impl AsRef<str>): String
        + {static} stderr_error(line: impl AsRef<str>): String
    }

    enum MessageType {
        Error
        Warning
        Success
        Info
        Command
        Question
    }

    enum AnsiColor {
        Black, Red, Green, Yellow, Blue, Magenta, Cyan, White
        BrightBlack, BrightRed, BrightGreen, BrightYellow
        BrightBlue, BrightMagenta, BrightCyan, BrightWhite
        Reset
        __
        + code(): &'static str
        + colorize(&self, text: &str): String
    }

    class AnsiStyle {
        {static} + BOLD: &str
        {static} + DIM: &str
        {static} + ITALIC: &str
        {static} + UNDERLINE: &str
        {static} + RESET: &str
        __
        + {static} bold(text: &str): String
        + {static} dim(text: &str): String
        + {static} italic(text: &str): String
        + {static} underline(text: &str): String
    }

    enum InfraError {
        Io(std::io::Error)
        CommandExecution(String)
        CommandNotFound(String)
        LLMRequest(String)
        Network(reqwest::Error)
        Parse(String)
        TerminalUI(String)
        PackageInstall(String)
        NoPackageManager
        Config(String)
        Generic(String)
        Other(anyhow::Error)
        __
        + command_execution(msg: impl Into<String>): Self
        + command_not_found(cmd: impl Into<String>): Self
        + llm_request(msg: impl Into<String>): Self
        + parse(msg: impl Into<String>): Self
        + terminal_ui(msg: impl Into<String>): Self
        + package_install(msg: impl Into<String>): Self
        + config(msg: impl Into<String>): Self
        + generic(msg: impl Into<String>): Self
        + is_command_not_found(): bool
        + message(): String
    }

    MessageFormatter ..> MessageType : <<uses>>
    MessageFormatter ..> AnsiColor : <<uses>>
}

' ==============================================================================
' MAIN RELATIONSHIPS
' ==============================================================================

InfrawareTerminal *-- TerminalUI
InfrawareTerminal *-- TerminalState
InfrawareTerminal *-- InputClassifier
InfrawareTerminal *-- EventHandler
InfrawareTerminal *-- CommandOrchestrator
InfrawareTerminal *-- NaturalLanguageOrchestrator
InfrawareTerminal *-- TabCompletionHandler

NaturalLanguageOrchestrator o-- LLMClientTrait
NaturalLanguageOrchestrator *-- ResponseRenderer

CommandOrchestrator ..> CommandExecutor : <<uses>>
CommandOrchestrator ..> PackageInstaller : <<uses>>
CommandOrchestrator ..> MessageFormatter : <<uses>>
CommandOrchestrator ..> TerminalState : <<uses>>
CommandOrchestrator ..> TerminalUI : <<uses>>

NaturalLanguageOrchestrator ..> MessageFormatter : <<uses>>
NaturalLanguageOrchestrator ..> TerminalState : <<uses>>
NaturalLanguageOrchestrator ..> TerminalUI : <<uses>>

TabCompletionHandler ..> TabCompletion : <<uses>>
TabCompletionHandler ..> MessageFormatter : <<uses>>
TabCompletionHandler ..> TerminalState : <<uses>>

InfrawareTerminal ..> TerminalEvent : <<uses>>
InfrawareTerminal ..> InputType : <<uses>>

note top of InfrawareTerminalBuilder
  <b>Builder Pattern</b>
  Costruisce InfrawareTerminal
  con dependency injection
end note

note top of CommandOrchestrator
  <b>Orchestrator Pattern</b>
  Gestisce il workflow di
  esecuzione comandi
end note

note top of PackageManager
  <b>Strategy Pattern</b>
  7 implementazioni per
  diversi package manager
end note

note top of InputHandler
  <b>Chain of Responsibility</b>
  5 handler per classificare
  input utente
end note

note top of CommandExecutionFacade
  <b>Facade Pattern</b>
  Semplifica l'interfaccia
  di esecuzione comandi
end note

@enduml
