@startuml Terminal UI Architecture
title "TerminalUI - State Management and Control Flow"

package "terminal" {
    class TerminalUI {
        -terminal: Terminal<CrosstermBackend<io::Stdout>>
        --
        +new() -> Result<Self>
        +render(state: &TerminalState) -> Result<()>
        +clear() -> Result<()>
        +cleanup() -> Result<()>
        +suspend() -> Result<()>
        +resume() -> Result<()>
    }

    note right of TerminalUI
        TUI lifecycle:
        1. new() → Initialize, enable raw mode
        2. render() → Draw UI repeatedly
        3. suspend() → Prepare for interactive command
        4. resume() → Restore TUI after command
        5. cleanup() → Restore terminal on exit
    end note

    enum TerminalMode {
        Normal
        ExecutingCommand
        WaitingLLM
        PromptingInstall
    }

    class TerminalState {
        +output: OutputBuffer
        +input: InputBuffer
        +history: CommandHistory
        +mode: TerminalMode
        --
        +new() -> Self
        +add_output(line: String)
        +submit_input() -> String
        +insert_char(c: char)
        +delete_char()
        +move_cursor_left()
        +move_cursor_right()
        +history_previous()
        +history_next()
        +scroll_up()
        +scroll_down()
    }

    TerminalState --> TerminalMode

    class OutputBuffer {
        -lines: Vec<String>
        -scroll_offset: usize
        -MAX_LINES: usize = 10000
        --
        +new() -> Self
        +add_line(line: String)
        +add_lines(lines: Vec<String>)
        +clear()
        +lines() -> &[String]
        +scroll_up()
        +scroll_down()
    }

    class InputBuffer {
        -text: String
        -cursor_pos: usize
        --
        +new() -> Self
        +text() -> &str
        +cursor_position() -> usize
        +insert_char(c: char)
        +delete_char()
        +move_left()
        +move_right()
        +set_text(text: &str)
        +take() -> String
        +clear()
    }

    class CommandHistory {
        -entries: Vec<String>
        -position: usize
        --
        +new() -> Self
        +add(cmd: String)
        +previous() -> Option<String>
        +next() -> Option<String>
        +reset_position()
        +all() -> &[String]
    }

    TerminalState --> OutputBuffer
    TerminalState --> InputBuffer
    TerminalState --> CommandHistory

    note right of OutputBuffer
        Auto-trim behavior:
        - Maximum 10,000 lines in memory
        - Older lines dropped when limit exceeded
        - Optimized for scrolling via scroll_offset
        - ANSI color codes parsed by ansi_to_tui
    end note

    note right of InputBuffer
        Unicode support:
        - Uses char count (not byte count) for cursor
        - Proper handling of CJK, emoji, etc.
        - set_text() uses .chars().count()
        - Cursor position accurate for all Unicode
    end note

    note right of CommandHistory
        Bidirectional navigation:
        - Store complete command history
        - Navigate with up/down arrows
        - Reset position after submit
        - Shared via Arc<RwLock> for history expansion
    end note
}

package "terminal::events" {
    enum TerminalEvent {
        Quit
        InputChar(char)
        DeleteChar
        MoveCursorLeft
        MoveCursorRight
        HistoryPrevious
        HistoryNext
        ScrollUp
        ScrollDown
        Submit
        TabComplete
        ClearScreen
        Resize(u16, u16)
        Unknown
    }

    class EventHandler {
        -tick_rate: Duration
        --
        +poll_event(timeout: Duration) -> Result<Option<TerminalEvent>>
    }

    note right of EventHandler
        Event polling:
        - Uses crossterm event system
        - Timeout-based polling (100ms default)
        - Filters KeyEventKind::Press only
        - No duplicate events on Windows
    end note
}

package "crossterm" {
    class CrosstermBackend {
        -output: io::Stdout
    }

    note right of CrosstermBackend
        Terminal control library:
        - enable_raw_mode() / disable_raw_mode()
        - EnterAlternateScreen / LeaveAlternateScreen
        - Cursor visibility control
    end note
}

package "ratatui" {
    class RataTuiTerminal {
        -backend: CrosstermBackend
        --
        +draw(f) -> Result<()>
        +clear() -> Result<()>
        +show_cursor() -> Result<()>
        +hide_cursor() -> Result<()>
    }

    note right of RataTuiTerminal
        TUI framework:
        - Renders frames efficiently
        - Manages screen layout
        - ANSI styling support
    end note
}

' Suspend/Resume Flow Detail
package "suspend_resume_flow" {
    object suspend_flow {
        title: "suspend() sequence"
        ---
        1. Show cursor
        2. Flush pending draws
        3. Leave alternate screen
        4. Disable raw mode
        5. Return to normal terminal
    }

    object resume_flow {
        title: "resume() sequence"
        ---
        1. Enable raw mode
        2. Enter alternate screen
        3. Clear screen
        4. Restore TUI state
        5. Ready for input
    }
}

' Relationships
TerminalUI --> RataTuiTerminal : "uses"
TerminalUI --> CrosstermBackend : "controls terminal"
TerminalUI --> TerminalState : "renders"
EventHandler --> TerminalEvent : "returns"
CrosstermBackend --> suspend_flow : "during suspend()"
CrosstermBackend --> resume_flow : "during resume()"

' Architecture notes
note bottom of TerminalUI
    Design: Separation of concerns
    - TerminalUI: Terminal control layer
    - TerminalState: Data/state management
    - EventHandler: Input polling

    Key responsibility:
    - Manage raw mode and alternate screen
    - Enable suspend/resume for interactive commands
    - Render UI state to terminal
end note

note bottom of TerminalState
    Single Responsibility Principle (SRP):
    - OutputBuffer: Scrollable output display
    - InputBuffer: User input with cursor
    - CommandHistory: Command history navigation
    - TerminalMode: Current operation mode

    Clean separation enables testing and reuse
end note

note bottom of EventHandler
    Event handling design:
    - Timeout-based polling (non-blocking)
    - Keyboard + terminal size events
    - Windows fix: Only KeyEventKind::Press
    - Async-friendly with Duration timeout

    Integration with async event loop
end note

@enduml
