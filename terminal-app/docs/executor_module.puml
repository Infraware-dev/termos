@startuml executor-module-detail
title "Executor Module - Command Execution & Package Management (Strategy Pattern)"

!define ACCENTCOLOR #4A90E2
!define PATTERNCOLOR #E8F4F8
!define STRATEGYCOLOR #F0E6FF

skinparam style strictuml
skinparam backgroundColor #FFFFFF
skinparam NoteBackgroundColor #FFFACD
skinparam NoteBorderColor #FFD700
skinparam ClassBackgroundColor #F5F5F5
skinparam ClassBorderColor ACCENTCOLOR

' Command Execution Core
package "Command Execution" {
    class CommandExecutor {
        + INTERACTIVE_COMMANDS: &[&str] (43 commands)
        --
        + execute(cmd: &str, args: &[String], original_input: Option<&str>): CommandOutput
        + execute_async(cmd: &str, args: &[String], original_input: Option<&str>): Future<CommandOutput>
        + execute_sudo(cmd: &str, args: &[String]): Future<CommandOutput>
        + command_exists(cmd: &str): bool
        --
        **Async execution** with tokio
        **Timeout**: 30 seconds default
        **Stream capture**: stdout/stderr
        **Exit code tracking**
    }

    class CommandOutput {
        + stdout: String
        + stderr: String
        + exit_code: i32
        --
        + is_success(): bool
        + combined_output(): String
    }

    note right of CommandExecutor
        **Interactive Commands Blocklist** (43 total):
        - Text editors: vi, vim, nvim, emacs, nano
        - System monitors: top, htop, btop, watch
        - File managers: mc, ranger, nnn, lf
        - Pagers: less, more, most, man
        - Network: ssh, telnet, ftp, sftp
        - Terminals: screen, tmux
        - REPLs: python, python3, node, ipython
        - Databases: mysql, psql, sqlite3, mongo
        - Debuggers: gdb, lldb, pdb
        - User-facing: passwd, su, sudo -i

        **Reason**: Require TTY, break in non-interactive
        **Handling**: User-friendly error messages with alternatives
    end note
}

' Package Management Strategy Pattern
package "Package Management (Strategy Pattern)" {
    interface PackageManager <<trait>> #STRATEGYCOLOR {
        + name(): &str
        + is_available(): bool
        + install(package: &str): Result<()>
        + priority(): u8
        --
        **async_trait** for async install()
        **Error handling** via anyhow::Result
    }

    class AptPackageManager implements PackageManager #STRATEGYCOLOR {
        + name(): &str = "apt-get"
        + is_available(): bool
        + install(package: &str): Result<()>
        + priority(): u8 = PRIORITY_MEDIUM
        --
        **Distribution**: Debian/Ubuntu
        **Dependencies**: sudo apt-get update
        **Flags**: -y for non-interactive
    }

    class YumPackageManager implements PackageManager #STRATEGYCOLOR {
        + name(): &str = "yum"
        + is_available(): bool
        + install(package: &str): Result<()>
        + priority(): u8 = PRIORITY_MEDIUM
        --
        **Distribution**: RedHat/CentOS
        **Command**: yum install -y <pkg>
    }

    class DnfPackageManager implements PackageManager #STRATEGYCOLOR {
        + name(): &str = "dnf"
        + is_available(): bool
        + install(package: &str): Result<()>
        + priority(): u8 = PRIORITY_HIGH
        --
        **Distribution**: Fedora (yum replacement)
        **Modern**: Better than yum
        **Priority**: Higher than yum
    }

    class PacmanPackageManager implements PackageManager #STRATEGYCOLOR {
        + name(): &str = "pacman"
        + is_available(): bool
        + install(package: &str): Result<()>
        + priority(): u8 = PRIORITY_MEDIUM
        --
        **Distribution**: Arch/Manjaro
        **Command**: pacman -S <pkg>
    }

    class BrewPackageManager implements PackageManager #STRATEGYCOLOR {
        + name(): &str = "brew"
        + is_available(): bool
        + install(package: &str): Result<()>
        + priority(): u8 = PRIORITY_VERY_HIGH
        --
        **Platform**: macOS (primary), Linux
        **Priority**: Highest (preferred on macOS)
        **No sudo**: User-level installation
    }

    class ChocoPackageManager implements PackageManager #STRATEGYCOLOR {
        + name(): &str = "choco"
        + is_available(): bool
        + install(package: &str): Result<()>
        + priority(): u8 = PRIORITY_LOW
        --
        **Platform**: Windows
        **Priority**: Lower than winget
        **Admin**: Requires elevation
    }

    class WingetPackageManager implements PackageManager #STRATEGYCOLOR {
        + name(): &str = "winget"
        + is_available(): bool
        + install(package: &str): Result<()>
        + priority(): u8 = PRIORITY_HIGH
        --
        **Platform**: Windows (modern)
        **Priority**: Higher than choco
        **Modern**: Microsoft's solution
    }

    note bottom of PackageManager
        **Strategy Pattern Benefits**:
        - Easy to add new managers without modifying existing code
        - Runtime selection based on availability + priority
        - Consistent interface across different managers
        - Testable via mock implementations
        - Platform-aware (Windows/Linux/macOS)
    end note

    note right of BrewPackageManager
        **Platform-Specific Priorities**:
        macOS:
        - Brew (priority: 90, VERY_HIGH)
        - Apt (shouldn't exist): 80
        Linux:
        - Dnf (priority: 85, HIGH)
        - Apt (priority: 80, MEDIUM)
        - Yum (priority: 80, MEDIUM)
        - Pacman (priority: 80, MEDIUM)
        Windows:
        - Winget (priority: 85, HIGH)
        - Choco (priority: 70, LOW)
    end note
}

' Package Installation Orchestrator
package "Package Installation" {
    class PackageInstaller {
        - package_managers: Vec<Arc<dyn PackageManager>>
        --
        + new(): Self
        + detect_package_manager(): Option<Arc<dyn PackageManager>>
        + install(package: &str): Result<()>
        --
        **Responsibilities**:
        - Detect available package managers
        - Select best one by priority + availability
        - Execute installation
    }

    note right of PackageInstaller
        **Manager Selection Algorithm**:
        1. Query all 7 managers for availability
        2. Filter to only available ones
        3. Sort by priority (highest first)
        4. Use first available
        5. Fallback: error if none available

        **Integration**: Facade pattern for auto-install workflow
        **Note**: Installation prompts but doesn't execute (M1 limitation)
    end note
}

' Tab Completion
package "Tab Completion" {
    class CompletionProvider {
        + complete_command(partial: &str): Vec<String>
        + complete_file(partial: &str): Vec<String>
        --
        **Command completion**:
        - Searches PATH
        - Filters by prefix
        - Returns available commands

        **File completion**:
        - Searches current directory
        - Expands glob patterns
        - Handles relative paths
    }

    note bottom of CompletionProvider
        **M1 Limitation**: Basic only
        - No bash/zsh completion integration
        - No context-aware suggestions
        - No cached completions
        (Deferred to M2/M3)
    end note
}

