@startuml architecture-overview
title "Infraware Terminal - Overall Architecture Diagram"

!define ACCENTCOLOR #4A90E2
!define MODULECOLOR #F5F5F5
!define PATTERNCOLOR #E8F4F8

skinparam style strictuml
skinparam backgroundColor #FFFFFF
skinparam NoteBackgroundColor #FFFACD
skinparam NoteBorderColor #FFD700
skinparam ClassBackgroundColor MODULECOLOR
skinparam ClassBorderColor ACCENTCOLOR

' Main Entry Point
package "Application Entry" {
    class InfrawareTerminal {
        - ui: TerminalUI
        - state: TerminalState
        - classifier: InputClassifier
        - event_handler: EventHandler
        - command_orchestrator: CommandOrchestrator
        - nl_orchestrator: NaturalLanguageOrchestrator
        - tab_completion_handler: TabCompletionHandler
        - history_arc: Arc<RwLock<Vec<String>>>
        --
        + handle_event(event: TerminalEvent)
        + handle_submit()
        + handle_command()
        + handle_natural_language()
        + handle_tab_completion()
    }

    class InfrawareTerminalBuilder <<builder>> #PATTERNCOLOR {
        - ui: Option<TerminalUI>
        - state: Option<TerminalState>
        - classifier: Option<InputClassifier>
        - llm_client: Option<Arc<dyn LLMClientTrait>>
        --
        + with_ui(ui: TerminalUI): Self
        + with_state(state: TerminalState): Self
        + with_classifier(classifier: InputClassifier): Self
        + with_llm_client(client: Arc<dyn LLMClientTrait>): Self
        + build(): Result<InfrawareTerminal>
    }
}

' Input Module (SCAN Algorithm)
package "input" {
    class InputClassifier {
        - chain: ClassifierChain
        - history: Option<Arc<RwLock<Vec<String>>>>
        --
        + classify(input: &str): Result<InputType>
        + with_history(history: Arc<RwLock>): Self
    }

    enum InputType {
        Command {command, args, original_input}
        NaturalLanguage(String)
        Empty
        CommandTypo {input, suggestion, distance}
    }

    class ClassifierChain #PATTERNCOLOR {
        - handlers: Vec<Box<dyn InputHandler>>
        --
        + add_handler(handler: Box<dyn InputHandler>): Self
        + process(input: &str): Option<InputType>
    }

    interface InputHandler <<trait>> {
        + handle(input: &str): Option<InputType>
    }

    class EmptyInputHandler implements InputHandler
    class HistoryExpansionHandler implements InputHandler
    class ShellBuiltinHandler implements InputHandler
    class PathCommandHandler implements InputHandler
    class KnownCommandHandler implements InputHandler
    class CommandSyntaxHandler implements InputHandler
    class TypoDetectionHandler implements InputHandler
    class NaturalLanguageHandler implements InputHandler
    class DefaultHandler implements InputHandler

    class CommandCache {
        - available: HashSet<String>
        - unavailable: HashSet<String>
        - aliases: HashMap<String, String>
        --
        + is_available(command: &str): bool
        + expand_alias(alias: &str): Option<String>
        + load_system_aliases(): Result<()>
        + load_user_aliases()
    }

    class CompiledPatterns {
        - command_syntax: RegexSet
        - natural_language: RegexSet
        - shell_operators: RegexSet
        - question_words: RegexSet
        - articles: RegexSet
        --
        + get(): &CompiledPatterns
        + has_shell_operators(input: &str): bool
    }
}

' Executor Module
package "executor" {
    class CommandExecutor {
        + INTERACTIVE_COMMANDS: &[&str]
        --
        + execute(cmd: &str, args: &[String], original_input: Option<&str>): CommandOutput
        + execute_sudo(cmd: &str, args: &[String]): CommandOutput
        + command_exists(cmd: &str): bool
    }

    class CommandOutput {
        + stdout: String
        + stderr: String
        + exit_code: i32
        --
        + is_success(): bool
        + combined_output(): String
    }

    class PackageInstaller {
        - package_managers: Vec<Arc<dyn PackageManager>>
        --
        + detect_package_manager(): Option<Arc<dyn PackageManager>>
        + install(package: &str): Result<()>
    }

    interface PackageManager <<trait>> #PATTERNCOLOR {
        + name(): &str
        + is_available(): bool
        + install(package: &str): Result<()>
        + priority(): u8
    }

    class AptPackageManager implements PackageManager #PATTERNCOLOR
    class YumPackageManager implements PackageManager #PATTERNCOLOR
    class DnfPackageManager implements PackageManager #PATTERNCOLOR
    class PacmanPackageManager implements PackageManager #PATTERNCOLOR
    class BrewPackageManager implements PackageManager #PATTERNCOLOR
    class ChocoPackageManager implements PackageManager #PATTERNCOLOR
    class WingetPackageManager implements PackageManager #PATTERNCOLOR

    class CompletionProvider {
        + complete_command(partial: &str): Vec<String>
        + complete_file(partial: &str): Vec<String>
    }
}

' Terminal Module
package "terminal" {
    class TerminalUI {
        + render(state: &TerminalState): Result<()>
    }

    class TerminalState {
        + output: OutputBuffer
        + input: InputBuffer
        + history: CommandHistory
        + mode: TerminalMode
        --
        + add_output(line: String)
        + insert_char(c: char)
        + submit_input(): String
        + history_previous()
        + history_next()
    }

    enum TerminalMode {
        Normal
        ExecutingCommand
        WaitingLLM
        PromptingInstall
    }

    class OutputBuffer {
        - buffer: Vec<String>
        - scroll_position: usize
        --
        + add_line(line: String)
        + add_lines(lines: Vec<String>)
        + scroll_up()
        + scroll_down()
        + clear()
    }

    class InputBuffer {
        - content: String
        - cursor_pos: usize
        --
        + insert_char(c: char)
        + delete_char()
        + move_cursor_left()
        + move_cursor_right()
        + content(): &str
    }
    note right of InputBuffer
        NOTE: Unicode handling correctly preserves
        grapheme boundaries for proper cursor movement
    end note

    class CommandHistory {
        - history: Vec<String>
        - position: Option<usize>
        --
        + add(command: String)
        + previous(): Option<String>
        + next(): Option<String>
        + all(): &[String]
    }

    class EventHandler {
        + poll_event(timeout: Duration): Result<Option<TerminalEvent>>
    }

    enum TerminalEvent {
        Quit
        InputChar(char)
        DeleteChar
        MoveCursorLeft
        MoveCursorRight
        HistoryPrevious
        HistoryNext
        ScrollUp
        ScrollDown
        Submit
        TabComplete
        ClearScreen
        Resize(u16, u16)
        Unknown
    }
}

' Orchestrators Module
package "orchestrators" {
    class CommandOrchestrator #PATTERNCOLOR {
        + handle_command(cmd: &str, args: &[String], original_input: Option<&str>, ...): Result<()>
    }

    class NaturalLanguageOrchestrator #PATTERNCOLOR {
        - llm_client: Arc<dyn LLMClientTrait>
        - renderer: ResponseRenderer
        --
        + handle_query(query: &str, state: &mut TerminalState, ui: &mut TerminalUI): Result<()>
    }

    class TabCompletionHandler #PATTERNCOLOR {
        + handle_tab_completion(state: &mut TerminalState)
    }
}

' LLM Module
package "llm" {
    interface LLMClientTrait <<trait>> {
        + query(text: &str): Result<String>
        + query_with_context(text: &str, context: Option<String>): Result<String>
        + query_with_history(text: &str, history: &[String]): Result<String>
    }

    class HttpLLMClient implements LLMClientTrait {
        - base_url: String
        - client: reqwest::Client
        --
        + new(base_url: String): Self
    }

    class MockLLMClient implements LLMClientTrait {
        + new(): Self
    }

    class ResponseRenderer {
        + render_markdown(response: &str): Vec<String>
        + highlight_code(code: &str, language: &str): String
    }

    class LLMRequest {
        + query: String
        + context: Option<String>
    }

    class LLMResponse {
        + text: String
        + metadata: Option<Value>
    }
}

' Utils Module
package "utils" {
    class MessageFormatter {
        + banner_line(text: &str): String
        + command(input: &str): String
        + error(message: &str): String
        + info(message: &str): String
        + success(message: &str): String
    }
}

' Relationships

' InfrawareTerminal composition
InfrawareTerminal *-- TerminalUI
InfrawareTerminal *-- TerminalState
InfrawareTerminal *-- InputClassifier
InfrawareTerminal *-- EventHandler
InfrawareTerminal *-- CommandOrchestrator
InfrawareTerminal *-- NaturalLanguageOrchestrator
InfrawareTerminal *-- TabCompletionHandler

' Builder Pattern
InfrawareTerminalBuilder ..> InfrawareTerminal : builds

' Input Module relationships
InputClassifier *-- ClassifierChain
ClassifierChain *-- InputHandler
InputClassifier --> InputType
ClassifierChain --> InputType
CommandCache -- CompiledPatterns

' Terminal Module relationships
TerminalState *-- OutputBuffer
TerminalState *-- InputBuffer
TerminalState *-- CommandHistory
TerminalState --> TerminalMode
TerminalUI --> TerminalState
EventHandler --> TerminalEvent

' Executor relationships
PackageInstaller --> PackageManager
CommandExecutor --> CommandOutput
CompletionProvider -- CommandExecutor

' Orchestrator relationships
CommandOrchestrator --> CommandExecutor
CommandOrchestrator --> PackageInstaller
CommandOrchestrator --> TerminalState
NaturalLanguageOrchestrator --> LLMClientTrait
NaturalLanguageOrchestrator --> ResponseRenderer
TabCompletionHandler --> CompletionProvider

' LLM relationships
ResponseRenderer --> LLMRequest
ResponseRenderer --> LLMResponse
LLMClientTrait --> LLMRequest
LLMClientTrait --> LLMResponse

' Data flow annotations
note right of InfrawareTerminal
    **Core Data Flow**:
    1. EventHandler polls terminal events
    2. handle_submit() gets user input
    3. InputClassifier routes to Command/NaturalLanguage
    4. CommandOrchestrator or NaturalLanguageOrchestrator
       handles the request
    5. TerminalUI renders updated TerminalState
end note

note bottom of InputClassifier
    **SCAN Algorithm** (Chain of Responsibility):
    1. EmptyInputHandler - Fast empty check
    2. HistoryExpansionHandler - !!,  !$, !^, !*
    3. ShellBuiltinHandler - ., :, [, [[, export, etc.
    4. PathCommandHandler - ./script, /usr/bin/cmd
    5. KnownCommandHandler - 60+ DevOps whitelist
    6. CommandSyntaxHandler - Flags, pipes, redirects
    7. TypoDetectionHandler - Levenshtein distance ≤2
    8. NaturalLanguageHandler - English patterns
    9. DefaultHandler - Fallback to NL
end note

note bottom of PackageManager
    **Strategy Pattern** for cross-platform:
    - Priority-based manager selection
    - Apt, Yum, Dnf, Pacman, Brew, Choco, Winget
    - Platform-aware (Windows/Linux/macOS)
end note

@enduml
