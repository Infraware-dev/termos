@startuml input-module-detail
title "Input Module - SCAN Algorithm & Chain of Responsibility Detail"

!define ACCENTCOLOR #4A90E2
!define PATTERNCOLOR #E8F4F8
!define HANDLERCOLOR #FFF4E6

skinparam style strictuml
skinparam backgroundColor #FFFFFF
skinparam NoteBackgroundColor #FFFACD
skinparam NoteBorderColor #FFD700
skinparam ClassBackgroundColor #F5F5F5
skinparam ClassBorderColor ACCENTCOLOR

' Core Classification Types
package "Input Classification Types" {
    enum InputType {
        **Command** {
            command: String
            args: Vec<String>
            original_input: Option<String>
        }
        **NaturalLanguage**(String)
        **Empty**
        **CommandTypo** {
            input: String
            suggestion: String
            distance: usize
        }
    }
}

' Classifier and Chain
package "Classifier Core" {
    class InputClassifier {
        - chain: ClassifierChain
        - history: Option<Arc<RwLock<Vec<String>>>>
        --
        + new(): Self
        + with_history(history: Arc<RwLock>): Self
        + classify(input: &str): Result<InputType>
        - classify_internal(input: &str): Result<InputType>
    }

    class ClassifierChain #PATTERNCOLOR {
        - handlers: Vec<Box<dyn InputHandler>>
        --
        + new(): Self
        + add_handler(handler: Box<dyn InputHandler>): Self
        + process(input: &str): Option<InputType>
    }

    note right of InputClassifier
        **Alias Expansion** (Pre-classification):
        1. Extract first word from input
        2. Check CommandCache.expand_alias()
        3. If found, classify expanded input
        4. If not found, classify original input
    end note

    note bottom of ClassifierChain
        **Processing order** (optimized for performance):
        Fast paths first → expensive checks later
    end note
}

' Handler Trait
package "Handler Interface" {
    interface InputHandler <<trait>> {
        + handle(input: &str): Option<InputType>
    }
}

' Handler Chain - Order Matters!
package "Handler Chain (9 Handlers in Strict Order)" {
    class Handler1_EmptyInputHandler implements InputHandler #HANDLERCOLOR {
        + handle(input: &str): Option<InputType>
        --
        **Responsibility**:
        Check if input is empty or whitespace
        **Performance**: <1μs
        **Failure**: Returns None, passes to next
    }

    class Handler2_HistoryExpansionHandler implements InputHandler #HANDLERCOLOR {
        - history: Option<Arc<RwLock<Vec<String>>>>
        --
        + with_history(history: Arc<RwLock>): Self
        + handle(input: &str): Option<InputType>
        --
        **Responsibility**:
        Expand Bash-style history patterns
        **Patterns**: !!, !$, !^, !*
        **Performance**: ~1-5μs (Arc<RwLock> overhead)
        **Thread-safe**: Via Arc<RwLock<Vec<String>>>
    }

    class Handler3_ShellBuiltinHandler implements InputHandler #HANDLERCOLOR {
        + handle(input: &str): Option<InputType>
        --
        **Responsibility**:
        Recognize shell builtins without PATH check
        **Commands**: 45+ (., :, [, [[, source, export)
        **Performance**: <1μs (string matching)
        **Key feature**: No PATH verification
    }

    class Handler4_PathCommandHandler implements InputHandler #HANDLERCOLOR {
        + handle(input: &str): Option<InputType>
        --
        **Responsibility**:
        Detect executable paths (unambiguous)
        **Patterns**: ./script.sh, /usr/bin/cmd
        **Performance**: ~10μs (filesystem checks)
        **Platform-aware**: Unix vs Windows
    }

    class Handler5_KnownCommandHandler implements InputHandler #HANDLERCOLOR {
        - known_commands: Vec<String>
        --
        + with_defaults(): Self
        + handle(input: &str): Option<InputType>
        --
        **Responsibility**:
        Check 60+ DevOps whitelist + PATH verification
        **Sources**: known_commands module
        **Performance**: <1μs cache hit, 1-5ms miss
        **Cache**: CommandCache with RwLock
    }

    class Handler6_CommandSyntaxHandler implements InputHandler #HANDLERCOLOR {
        + handle(input: &str): Option<InputType>
        --
        **Responsibility**:
        Detect command syntax indicators
        **Patterns**: Flags (--/-), pipes (|), redirects
        **Performance**: ~10μs (regex match)
        **Patterns**: Via CompiledPatterns singleton
    }

    class Handler7_TypoDetectionHandler implements InputHandler #HANDLERCOLOR {
        - known_commands: Vec<String>
        --
        + with_defaults(): Self
        + handle(input: &str): Option<InputType>
        --
        **Responsibility**:
        Detect command typos via Levenshtein distance
        **Distance threshold**: ≤2
        **Performance**: ~100μs (strsim crate)
        **Prevention**: Avoids false LLM calls
    }

    class Handler8_NaturalLanguageHandler implements InputHandler #HANDLERCOLOR {
        + handle(input: &str): Option<InputType>
        --
        **Responsibility**:
        Detect English-only natural language patterns
        **Patterns**: Questions, articles, polite phrases
        **Performance**: ~5μs (precompiled regex)
        **Multilingual**: Passed to LLM via DefaultHandler
    }

    class Handler9_DefaultHandler implements InputHandler #HANDLERCOLOR {
        + handle(input: &str): Option<InputType>
        --
        **Responsibility**:
        Fallback to natural language (guarantees result)
        **Pattern**: Matches everything
        **Performance**: <1μs
        **Guarantee**: Never returns None
    }
}

' Supporting modules
package "Supporting Services" {
    class CommandCache {
        - available: HashSet<String>
        - unavailable: HashSet<String>
        - aliases: HashMap<String, String>
        --
        + is_available(command: &str): bool
        + expand_alias(alias: &str): Option<String>
        + load_system_aliases(): Result<()>
        + load_user_aliases(): Result<()>
        --
        **Singleton Pattern**: Static COMMAND_CACHE
        **Thread-safe**: RwLock<CommandCache>
        **Poisoning**: Recovery via into_inner()
    }

    note right of CommandCache
        **Alias Loading Priority**:
        System first (lower priority):
        - /etc/bash.bashrc
        - /etc/bashrc
        - /etc/profile
        - /etc/profile.d/*.sh

        User second (higher priority):
        - ~/.bashrc
        - ~/.bash_aliases
        - ~/.zshrc
    end note

    class CompiledPatterns {
        - command_syntax: RegexSet
        - natural_language: RegexSet
        - shell_operators: RegexSet
        - question_words: RegexSet
        - articles: RegexSet
        --
        + get(): &CompiledPatterns
        + has_shell_operators(input: &str): bool
        --
        **Singleton Pattern**: Static PATTERNS
        **Lazy Initialization**: once_cell::Lazy
        **Performance**: 10-100x faster than runtime compilation
    }

    note bottom of CompiledPatterns
        **Precompiled Patterns** (once_cell::Lazy):
        - Command syntax: Flags, relative paths, env vars
        - Natural language: Question marks, articles
        - Shell operators: Pipes, redirects, subshells
        - Question words: How, what, why, when, etc.
        - Articles: a, an, the (English only)
    end note

    class HistoryExpansionState {
        + patterns: [!!, !$, !^, !*]
        --
        + expand_bang_bang(history: &Vec<String>): Result<String>
        + expand_bang_dollar(history: &Vec<String>): Result<String>
        + expand_bang_caret(history: &Vec<String>): Result<String>
        + expand_bang_star(history: &Vec<String>): Result<String>
    }

    note bottom of HistoryExpansionState
        **History Expansion Semantics**:
        - !!  → entire previous command
        - !$  → last argument (or command if no args)
        - !^  → first argument (fails if no args)
        - !*  → all arguments (fails if no args)
        Multiple expansions per input supported
        Preserves shell operators in expanded output
    end note

    class ShellBuiltinInfo {
        + name: &str
        + requires_shell: bool
        + unix_only: bool
        --
        + builtin_list(): Vec<ShellBuiltinInfo>
    }

    note bottom of ShellBuiltinInfo
        **45+ Shell Builtins Recognized**:
        Punctuation: ., :, [, [[, test
        Evaluation: eval, exec
        Variables: export, unset, set
        I/O: echo, printf
        Job control: jobs, fg, bg
        Flow: if, for, while, case
    end note
}

' Relationships
InputClassifier *-- ClassifierChain
ClassifierChain *-- InputHandler

Handler1_EmptyInputHandler -- InputType
Handler2_HistoryExpansionHandler -- InputType
Handler3_ShellBuiltinHandler -- InputType
Handler4_PathCommandHandler -- InputType
Handler5_KnownCommandHandler -- InputType
Handler6_CommandSyntaxHandler -- InputType
Handler7_TypoDetectionHandler -- InputType
Handler8_NaturalLanguageHandler -- InputType
Handler9_DefaultHandler -- InputType

Handler2_HistoryExpansionHandler --> HistoryExpansionState
Handler3_ShellBuiltinHandler --> ShellBuiltinInfo
Handler5_KnownCommandHandler --> CommandCache
Handler6_CommandSyntaxHandler --> CompiledPatterns
Handler7_TypoDetectionHandler --> CommandCache
Handler8_NaturalLanguageHandler --> CompiledPatterns

InputClassifier --> CommandCache

' Flow diagram
note top of InputClassifier
    **Processing Flow**:
    1. classify(input) calls CommandCache.expand_alias()
    2. If alias found, recursively classify expanded input
    3. Otherwise, call classify_internal()
    4. Process through ClassifierChain
    5. First handler to return Some() wins
    6. DefaultHandler always matches (never None)
end note

note bottom of Handler9_DefaultHandler
    **Chain Guarantee**:
    DefaultHandler at position 9 ensures
    the chain ALWAYS returns a result.
    This prevents "None case" handling.
end note

' Performance summary
note right of CompiledPatterns
    **Performance Summary** (Per Classification):
    - Average: <100μs
    - Known command (cache hit): <1μs
    - Typo detection: ~100μs
    - Natural language: ~5μs
    - PATH lookup (cache miss): 1-5ms
    - Precompiled regex overhead: ~0μs

    **Optimization Techniques**:
    - Fast paths first (empty, history)
    - Precompiled regex (once_cell::Lazy)
    - Thread-safe caching (RwLock + hash)
    - Handler ordering (70% hit known commands)
    - Zero-cost abstractions (static dispatch)
end note

@enduml
