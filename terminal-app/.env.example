# Infraware Terminal - Environment Configuration
# Copy this file to .env and adjust values as needed

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level: trace, debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Maximum log file size in MB before rotation
# Default: 10 (MB)
LOG_MAX_SIZE_MB=10

# Maximum number of rotated log files to keep
# Older files will be automatically deleted
# Default: 5
LOG_MAX_FILES=5

# Custom log directory path (optional)
# If empty, uses platform-specific default:
#   - Linux: ~/.local/share/infraware-terminal/logs
#   - macOS: ~/Library/Logs/infraware-terminal
#   - Windows: %APPDATA%\infraware-terminal\logs
# Default: (empty - auto-detect)
LOG_PATH=
