# Backend configuration - copy to .env

# Engine type: mock or rig
ENGINE_TYPE=rig

# For rig engine
ANTHROPIC_MODEL=claude-sonnet-4-20250514
RIG_MAX_TOKENS=4096
RIG_TIMEOUT_SECS=300
RIG_TEMPERATURE=0.7

# Server
PORT=8080
ALLOWED_ORIGINS=*

# Authentication (leave empty to disable)
API_KEY=

# Rate limiting (0 = disabled)
RATE_LIMIT_RPM=100

# Logging
RUST_LOG=infraware_backend=debug
